<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.MainController"
            styleClass="mainRoot">

    <!-- ═══ BARRA SUPERIOR DE SESIÓN ═══ -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 10 24; -fx-background-color: rgba(0,0,0,0.06);">
            <!-- Chip usuario / rol -->
            <HBox styleClass="sessionChip" spacing="10" alignment="CENTER">
                <Label fx:id="lblUsuarioNombre" text="—" styleClass="sessionName"/>
                <Label text="|" style="-fx-text-fill: #d1d5db;"/>
                <Label fx:id="lblUsuarioRol"    text="—" styleClass="sessionRole"/>
            </HBox>
            <!-- Botón cerrar sesión -->
            <Button text="🔓  Cerrar Sesión"
                    onAction="#cerrarSesion"
                    styleClass="btnCerrarSesion"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="26" styleClass="mainWrapper">
            <padding>
                <Insets top="30" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Logo y bienvenida -->
            <VBox alignment="CENTER" spacing="10" styleClass="mainTopPanel">
                <StackPane styleClass="mainLogoWrap">
                    <ImageView fx:id="logoImage"
                               fitWidth="150"
                               fitHeight="150"
                               preserveRatio="true"
                               smooth="true"/>
                </StackPane>

                <Label text="Bienvenidos a Salsiao" styleClass="mainBrand"/>
                <Label text="Selecciona el módulo que deseas gestionar" styleClass="mainSubtitle"/>
            </VBox>

            <!-- Botones de módulos (con fx:id para control de visibilidad por rol) -->
            <GridPane hgap="18" vgap="18" alignment="CENTER">
                <Button fx:id="btnCompras"
                        text="🛒  Compras"
                        onAction="#abrirCompras"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                <Button fx:id="btnMantenimiento"
                        text="🔧  Mantenimiento"
                        onAction="#abrirMantenimiento"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Button fx:id="btnEmpleados"
                        text="👤  Empleados"
                        onAction="#abrirEmpleados"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnGreen"
                        GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                <Button fx:id="btnInventario"
                        text="📦  Inventario"
                        onAction="#abrirInventario"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnGreen"
                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button fx:id="btnClientes"
                        text="🧑  Clientes"
                        onAction="#abrirClientes"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnOrange"
                        GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                <Button fx:id="btnVentas"
                        text="💳  Ventas"
                        onAction="#abrirVentas"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnOrange"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button text="⏻  Salir del Sistema"
                        onAction="#salirSistema"
                        prefWidth="458" prefHeight="68"
                        styleClass="mainBtnExit"
                        GridPane.rowIndex="3" GridPane.columnIndex="0"
                        GridPane.columnSpan="2"/>
            </GridPane>
        </VBox>
    </center>

</BorderPane>