<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<!--
    login.fxml - Pantalla de inicio de sesión Salsiao (Premium UI)
    Controller: LoginController.java
    Diseño: Tarjeta glassmorphism centrada
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.salsiaopf.controller.LoginController"
           prefWidth="1200" prefHeight="800"
           styleClass="loginRoot">

    <!-- Tarjeta principal glassmorphism -->
    <VBox fx:id="panelLogin"
          styleClass="loginCard"
          alignment="CENTER"
          spacing="28"
          maxWidth="400">

        <!-- Logo Salsiao -->
        <VBox alignment="CENTER" spacing="4">
            <Label text="🌶️" styleClass="loginLogoEmoji"/>
            <Label text="Salsiao" styleClass="loginLogoName"/>
            <Label text="Sistema de Gestión" styleClass="loginLogoTagline"/>
        </VBox>

        <!-- Separador decorativo -->
        <Region styleClass="loginDivider" maxWidth="60"/>

        <!-- Formulario -->
        <VBox spacing="20" maxWidth="Infinity">

            <!-- Campo: Usuario -->
            <VBox spacing="6">
                <Label text="Usuario" styleClass="loginFieldLabel"/>
                <HBox styleClass="loginInputGroup">
                    <Label text="👤" styleClass="loginInputIcon"/>
                    <TextField fx:id="txtUsuario"
                               promptText="Ingresa tu usuario"
                               HBox.hgrow="ALWAYS"
                               styleClass="loginField"/>
                </HBox>
            </VBox>

            <!-- Campo: Contraseña -->
            <VBox spacing="6">
                <Label text="Contraseña" styleClass="loginFieldLabel"/>
                <HBox fx:id="hboxContrasena" styleClass="loginInputGroup">
                    <Label text="🔒" styleClass="loginInputIcon"/>
                    <PasswordField fx:id="txtContrasena"
                                   promptText="••••••••"
                                   HBox.hgrow="ALWAYS"
                                   styleClass="loginField"/>
                    <TextField fx:id="txtContrasenaVisible"
                               promptText="••••••••"
                               HBox.hgrow="ALWAYS"
                               styleClass="loginField"/>
                    <Button fx:id="btnMostrarContrasena"
                            text="👁"
                            onAction="#toggleContrasena"
                            styleClass="loginBtnToggle"/>
                </HBox>
            </VBox>

            <!-- Mensaje de error -->
            <Label fx:id="lblError"
                   styleClass="loginErrorLabel"
                   wrapText="true"/>

            <!-- Indicador de carga -->
            <ProgressIndicator fx:id="progressLogin"
                               prefWidth="32" prefHeight="32"
                               styleClass="loginProgress"/>

            <!-- Botón Ingresar -->
            <Button fx:id="btnIngresar"
                    text="Ingresar"
                    onAction="#iniciarSesion"
                    maxWidth="Infinity"
                    styleClass="loginBtnPrimary"/>

        </VBox>

        <!-- Footer -->
        <Label fx:id="lblVersion"
               text="Salsiao Sistema de Gestión · Todos los derechos reservados"
               styleClass="loginFooter"/>

    </VBox>

</StackPane>
