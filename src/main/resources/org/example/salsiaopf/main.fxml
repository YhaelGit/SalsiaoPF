<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.MainController"
            styleClass="mainRoot">

    <center>
        <VBox alignment="CENTER" spacing="26" styleClass="mainWrapper">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Logo y bienvenida -->
            <VBox alignment="CENTER" spacing="10" styleClass="mainTopPanel">
                <StackPane styleClass="mainLogoWrap">
                    <ImageView fx:id="logoImage"
                               fitWidth="150"
                               fitHeight="150"
                               preserveRatio="true"
                               smooth="true"/>
                </StackPane>

                <Label text="Bienvenidos a Salsiao" styleClass="mainBrand"/>
            </VBox>

            <!-- Botones -->
            <GridPane hgap="18" vgap="18" alignment="CENTER">
                <Button text="Compras"
                        onAction="#abrirCompras"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                <Button text="Mantenimiento"
                        onAction="#abrirMantenimiento"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Button text="Empleados"
                        onAction="#abrirEmpleados"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                <Button text="Inventario"
                        onAction="#abrirInventario"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button text="Cliente"
                        onAction="#abrirClientes"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="2" GridPane.columnIndex="0"/>

                <Button text="Ventas"
                        onAction="#abrirVentas"
                        prefWidth="220" prefHeight="72"
                        styleClass="mainBtnBlue"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button text="Salir"
                        onAction="#salirSistema"
                        prefWidth="458" prefHeight="68"
                        styleClass="mainBtnExit"
                        GridPane.rowIndex="3" GridPane.columnIndex="0"
                        GridPane.columnSpan="2"/>
            </GridPane>
        </VBox>
    </center>

</BorderPane>