<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.CompraController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Compras" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>

            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 0"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="COMPRAS" styleClass="sideTitle"/>

            <Button fx:id="btnOrdenCompra" text="🛒  Orden de compra" onAction="#mostrarOrdenCompra" styleClass="sideButtonActive"/>
            <Button fx:id="btnProveedores" text="🏢  Proveedores" onAction="#mostrarProveedores" styleClass="sideButton"/>
            <Button fx:id="btnRecepcion" text="📥  Recepción" onAction="#mostrarRecepcion" styleClass="sideButton"/>
            <Button fx:id="btnAnalisisDeCompra" text="🥬  Análisis de Compra" onAction="#mostrarAnalisisCompras" styleClass="sideButton"/>
            <Button fx:id="btnPagosCompra" text="💳  Pagos de compra" onAction="#mostrarPagosCompra" styleClass="sideButton"/>
            <Button fx:id="btnHistorialCompras" text="↺  Historial de compras" onAction="#mostrarHistorialCompras" styleClass="sideButton"/>

            <Region VBox.vgrow="ALWAYS"/>

                <VBox styleClass="userCard">
                    <Label text="Compras"
                           styleClass="userCardName"/>

                    <Label text="Gestión de compras."
                           wrapText="true"
                           styleClass="userCardRole"/>
                </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorCompras" styleClass="contentArea">

            <!-- ORDEN DE COMPRA -->
            <VBox fx:id="viewOrdenCompra" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Orden de compra" styleClass="pageTitle"/>
                        <Label text="Crea y envía solicitudes de ingredientes a proveedores." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva orden" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="📤 Enviar orden" styleClass="actionGreen"/>
                    <Button text="✖ Cancelar orden" styleClass="actionRed"/>
                    <Button text="💾 Guardar" onAction="#guardarOrdenCompra" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarOrdenCompra" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardOrange" prefWidth="220" prefHeight="95" GridPane.columnIndex="0">
                        <Label text="Pendientes"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Órdenes sin enviar"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardBlue" prefWidth="220" prefHeight="95" GridPane.columnIndex="1">
                        <Label text="Enviadas"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Esperando recepción"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardGreen" prefWidth="220" prefHeight="95" GridPane.columnIndex="2">
                        <Label text="Recibidas"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Este mes"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardPurple" prefWidth="260" prefHeight="95" GridPane.columnIndex="3">
                        <Label text="Ingredientes solicitados"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Este mes"/>
                    </VBox>

                </GridPane>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" prefWidth="980" maxWidth="980">

                        <Label text="Datos de la orden" styleClass="cardTitle"/>

                        <GridPane hgap="16" vgap="12">

                            <columnConstraints>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                            </columnConstraints>

                            <Label text="No. orden:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Solicitado por:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField promptText="Usuario" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Proveedor:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtProveedorOrden" promptText="Nombre del proveedor" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Sucursal:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Sucursal" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Fecha solicitud:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <DatePicker GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Estado:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Borrador / Enviada / Recibida / Cancelada" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Fecha esperada:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <DatePicker GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Observación:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextArea promptText="Instrucciones para el proveedor..."
                                      prefRowCount="3"
                                      wrapText="true"
                                      GridPane.rowIndex="4"
                                      GridPane.columnIndex="1"
                                      GridPane.columnSpan="3"/>

                        </GridPane>

                    </VBox>

                    <VBox styleClass="cardPanel compactPanel" spacing="12" prefWidth="320" minWidth="320" maxWidth="320">

                        <Label text="Resumen de la orden" styleClass="cardTitle"/>

                        <HBox>
                            <Label text="Proveedor:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="N/A"/>
                        </HBox>

                        <HBox>
                            <Label text="Estado:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Borrador"/>
                        </HBox>

                        <HBox>
                            <Label text="Fecha esperada:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="--/--/----"/>
                        </HBox>

                        <Separator/>

                        <HBox>
                            <Label text="Ingredientes:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <HBox>
                            <Label text="Unidades:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Total (RD$):"/>
                            <TextField fx:id="txtTotalOrden" promptText="0.00" prefWidth="120"/>
                        </HBox>

                        <Separator/>

                        <Button text="📤 Enviar orden" styleClass="actionGreen" maxWidth="Infinity"/>
                        <Button text="📋 Duplicar orden" styleClass="actionBlue" maxWidth="Infinity"/>
                        <Button text="✔ Marcar recibida" styleClass="actionBlue" maxWidth="Infinity"/>
                        <Button text="✖ Cancelar orden" styleClass="actionRed" maxWidth="Infinity"/>

                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Detalle solicitado" styleClass="cardTitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <ComboBox promptText="Ingrediente" prefWidth="230"/>
                        <ComboBox promptText="Unidad" prefWidth="150"/>
                        <TextField promptText="Cantidad" prefWidth="120"/>
                        <TextField promptText="Nota opcional" prefWidth="220"/>
                        <Button text="+ Agregar" styleClass="actionBlue"/>
                    </HBox>

                    <TableView prefHeight="300" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Ingrediente" prefWidth="200"/>
                            <TableColumn text="Unidad" prefWidth="150"/>
                            <TableColumn text="Cantidad solicitada" prefWidth="190"/>
                            <TableColumn text="Nota" prefWidth="300"/>
                            <TableColumn text="Estado" prefWidth="150"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mostrando ingredientes solicitados"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="La recepción comparará lo solicitado contra lo recibido."/>
                    </HBox>

                </VBox>

            </VBox>

            <VBox fx:id="viewProveedores" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Proveedores" styleClass="pageTitle"/>
                        <Label text="Administra proveedores, datos fiscales, contactos y sucursales." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo proveedor" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" styleClass="actionRed"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del proveedor" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">

                            <Label text="ID Proveedor:" minWidth="130" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtIdProveedor" editable="false" promptText="Automático" prefWidth="260"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="RNC:" minWidth="130" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtRncProveedor" promptText="RNC" prefWidth="240"
                                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Nombre:" minWidth="130" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombreProveedor" promptText="Nombre del proveedor" prefWidth="260"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Teléfono:" minWidth="130" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtTelefonoProveedor" promptText="Teléfono" prefWidth="240"
                                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Dirección:" minWidth="130" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtDireccionProveedor" promptText="Dirección principal" prefWidth="260"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Estado:" minWidth="130" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbEstadoProveedor" promptText="Activo" prefWidth="240"
                                      GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Correo:" minWidth="130" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtCorreoProveedor" promptText="Correo opcional" prefWidth="260"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Observaciones:" minWidth="130" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <TextArea fx:id="txtObservacionProveedor" promptText="Observaciones..."
                                      prefRowCount="3" prefWidth="240"
                                      GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="14" prefWidth="390">
                        <Label text="Búsqueda rápida" styleClass="cardTitle"/>

                        <HBox spacing="10">
                            <ComboBox fx:id="cmbTipoBusquedaProveedor" promptText="Nombre" prefWidth="130"/>
                            <TextField fx:id="txtBuscarProveedor" promptText="Buscar proveedor..." HBox.hgrow="ALWAYS"/>
                            <Button text="🔍" styleClass="actionBlue"/>
                        </HBox>

                        <Separator/>

                        <Label text="Resumen de proveedores" styleClass="cardTitle"/>

                        <HBox>
                            <Label text="Activos:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="25"/>
                        </HBox>

                        <HBox>
                            <Label text="Inactivos:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="3"/>
                        </HBox>

                        <HBox>
                            <Label text="Con compras:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="18"/>
                        </HBox>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de proveedores" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Quitar sucursal" styleClass="actionRed"/>
                        <Button text="↻ Actualizar" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaProveedores" prefHeight="300">
                        <columns>
                            <TableColumn text="ID Proveedor" prefWidth="130"/>
                            <TableColumn text="Nombre" prefWidth="150"/>
                            <TableColumn text="RNC" prefWidth="150"/>
                            <TableColumn text="Teléfono" prefWidth="160"/>
                            <TableColumn text="Dirección" prefWidth="250"/>
                            <TableColumn text="Estado" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <VBox fx:id="viewRecepcion" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Recepción de mercancía" styleClass="pageTitle"/>
                        <Label text="Recibe, valida y actualiza inventario desde las compras realizadas." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="📥 Recibir compra" styleClass="actionBlue"/>
                    <Button text="✔ Confirmar recepción" styleClass="actionGreen"/>
                    <Button text="✖ Rechazar" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de recepción" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="Orden compra:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbOrdenRecepcion" promptText="Seleccionar orden" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Proveedor:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtProveedorRecepcion" editable="false" promptText="Proveedor" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Fecha recepción:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <DatePicker fx:id="dateRecepcion" prefWidth="280" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbEstadoRecepcion" promptText="Pendiente" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Recibido por:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtRecibidoPor" editable="false" promptText="Admin" prefWidth="280" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Observación:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextArea fx:id="txtObservacionRecepcion" promptText="Observación de recepción..." prefRowCount="3" prefWidth="260"
                                      GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="12" prefWidth="390">
                        <Label text="Resumen de recepción" styleClass="cardTitle"/>

                        <HBox>
                            <Label text="Pendientes:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="5"/>
                        </HBox>

                        <HBox>
                            <Label text="Recibidas hoy:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="8"/>
                        </HBox>

                        <HBox>
                            <Label text="Rechazadas:"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="1"/>
                        </HBox>

                        <Separator/>

                        <Button text="Ver órdenes pendientes" styleClass="actionBlue" prefHeight="42"/>
                        <Button text="Actualizar inventario" styleClass="actionGreen" prefHeight="42"/>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Detalle recibido" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField promptText="Buscar ingrediente..." prefWidth="240"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaRecepcion" prefHeight="420">
                        <columns>
                            <TableColumn text="Ingrediente" prefWidth="260"/>
                            <TableColumn text="Cantidad comprada" prefWidth="160"/>
                            <TableColumn text="Cantidad recibida" prefWidth="160"/>
                            <TableColumn text="Unidad" prefWidth="120"/>
                            <TableColumn text="Costo unidad" prefWidth="140"/>
                            <TableColumn text="Vencimiento" prefWidth="150"/>
                        </columns>
                    </TableView>

                </VBox>

            </VBox>

            <VBox fx:id="viewAnalisisCompras"
                  styleClass="content"
                  spacing="16"
                  visible="false"
                  managed="false">

             <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox>
                    <Label text="Análisis de compras" styleClass="pageTitle"/>
                    <Label text="Analiza ingredientes comprados, costos, proveedores y variaciones de precio." styleClass="pageSubtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="📦 Nuevo ingrediente" styleClass="actionBlue"/>
                <Button text="✎ Editar costo" styleClass="actionOrange"/>
                <Button text="📊 Actualizar análisis" styleClass="actionGreen"/>
                <Button text="↻ Actualizar" styleClass="actionNeutral"/>
             </HBox>

             <GridPane hgap="16">

                <VBox alignment="CENTER" spacing="6" styleClass="statusCardBlue" prefWidth="220" prefHeight="95" GridPane.columnIndex="0">
                    <Label text="Compras registradas"/>
                    <Label text="0" styleClass="metricValueSmall"/>
                    <Label text="Este periodo"/>
                </VBox>

                <VBox alignment="CENTER" spacing="6" styleClass="statusCardGreen" prefWidth="220" prefHeight="95" GridPane.columnIndex="1">
                    <Label text="Total invertido"/>
                    <Label text="RD$ 0.00" styleClass="metricValueSmall"/>
                    <Label text="Compras"/>
                </VBox>

                <VBox alignment="CENTER" spacing="6" styleClass="statusCardOrange" prefWidth="220" prefHeight="95" GridPane.columnIndex="2">
                    <Label text="Ingrediente más comprado"/>
                    <Label text="N/A" styleClass="metricValueSmall"/>
                    <Label text="Mayor demanda"/>
                </VBox>

                <VBox alignment="CENTER" spacing="6" styleClass="statusCardRed" prefWidth="220" prefHeight="95" GridPane.columnIndex="3">
                    <Label text="Costos elevados"/>
                    <Label text="0" styleClass="metricValueSmall"/>
                    <Label text="Revisar precios"/>
                </VBox>

            </GridPane>

            <HBox spacing="16">

                <VBox styleClass="cardPanel" spacing="12" prefWidth="980" maxWidth="980">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Filtro" styleClass="cardTitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <TextField promptText="Buscar ingrediente..." prefWidth="220"/>
                        <ComboBox promptText="Proveedor" prefWidth="180"/>
                        <ComboBox promptText="Categoría" prefWidth="160"/>
                        <ComboBox promptText="Estado stock" prefWidth="160"/>
                        <Button text="🔍 Buscar" styleClass="actionBlue"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <DatePicker promptText="Desde" prefWidth="150"/>
                        <DatePicker promptText="Hasta" prefWidth="150"/>
                        <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView prefHeight="500" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Ingrediente" prefWidth="220"/>
                            <TableColumn text="Última compra" prefWidth="140"/>
                            <TableColumn text="Proveedor" prefWidth="220"/>
                            <TableColumn text="Costo actual" prefWidth="130"/>
                            <TableColumn text="Costo anterior" prefWidth="140"/>
                            <TableColumn text="Variación" prefWidth="120"/>
                            <TableColumn text="Stock actual" prefWidth="130"/>
                            <TableColumn text="Estado" prefWidth="130"/>
                            <TableColumn text="Acciones" prefWidth="130"/>
                        </columns>
                    </TableView>

                </VBox>

                <VBox styleClass="cardPanel compactPanel" spacing="12" prefWidth="320" minWidth="320" maxWidth="320">

                    <Label text="Alertas de compra" styleClass="cardTitle"/>

                    <VBox spacing="10">
                        <Label text="• Ingredientes con costo elevado"/>
                        <Label text="• Ingredientes sin compras recientes"/>
                        <Label text="• Stock bajo o crítico"/>
                        <Label text="• Proveedores inactivos"/>
                    </VBox>

                    <Separator/>

                    <Label text="Detalle rápido" styleClass="cardTitle"/>

                    <Label text="Ingrediente:"/>
                    <TextField promptText="N/A" editable="false"/>

                    <Label text="Proveedor principal:"/>
                    <TextField promptText="N/A" editable="false"/>

                    <Label text="Último costo:"/>
                    <TextField promptText="RD$ 0.00" editable="false"/>

                    <Label text="Variación:"/>
                    <TextField promptText="0%" editable="false"/>

                    <Button text="Ver historial" styleClass="actionBlue" maxWidth="Infinity"/>
                    <Button text="Comparar proveedores" styleClass="actionGreen" maxWidth="Infinity"/>

                </VBox>

            </HBox>

        </VBox>

            <VBox fx:id="viewPagosCompra" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Pagos de compra" styleClass="pageTitle"/>
                        <Label text="Registra pagos realizados a proveedores y controla facturas pendientes." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo pago" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗑 Anular" styleClass="actionRed"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del pago" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">

