<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.CompraController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage" fitWidth="82" fitHeight="82" preserveRatio="true"/>
            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Compras" styleClass="brandSubtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>
            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>
                <Button fx:id="btnNotificaciones" text="🔔 0" onAction="#mostrarNotificaciones" styleClass="notificationModernButton"/>
                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="COMPRAS" styleClass="sideTitle"/>
            <Button text="🛒  Orden de compra" onAction="#mostrarOrdenCompra" styleClass="sideButtonActive"/>
            <Button text="🏢  Proveedores" onAction="#mostrarProveedores" styleClass="sideButton"/>
            <Button text="📥  Recepción" onAction="#mostrarRecepcion" styleClass="sideButton"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="userCard">
                <Label text="Compras" styleClass="userCardName"/>
                <Label text="Gestión de compras." wrapText="true" styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorCompras" styleClass="contentArea">

            <!-- ═══════════════ ORDEN DE COMPRA ═══════════════ -->
            <ScrollPane fx:id="scrollOrdenCompra" fitToWidth="true" fitToHeight="true" visible="true" managed="true" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Orden de compra" styleClass="pageTitle"/>
                        <Label text="Crea órdenes de compra seleccionando proveedor e ingredientes." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar orden" onAction="#guardarOrdenCompra" styleClass="actionGreen"/>
                    <Button text="↻ Nueva orden" onAction="#nuevaOrdenCompra" styleClass="actionBlue"/>
                    <Button text="↻ Limpiar" onAction="#limpiarOrdenCompra" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="260" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Órdenes pendientes"/>
                        <Label fx:id="lblMetricaPendientes" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="260" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Recibidas este mes"/>
                        <Label fx:id="lblMetricaRecibidas" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="260" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Total invertido"/>
                        <Label fx:id="lblMetricaTotal" text="RD$ 0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <HBox spacing="16">
                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de la orden" styleClass="cardTitle"/>
                        <GridPane hgap="16" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="240" prefWidth="240"/>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="240" prefWidth="240"/>
                            </columnConstraints>

                            <Label text="Código orden:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtCodigoOrden" editable="false" promptText="Auto-generado" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Fecha:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <DatePicker fx:id="dateFechaOrden" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Proveedor:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbProveedorOrden" promptText="Seleccionar proveedor" prefWidth="240" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Estado:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField text="Pendiente" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Notas de orden:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextArea fx:id="txtNotasOrden" promptText="Especificaciones extra, instrucciones de entrega, condiciones especiales..." prefRowCount="3" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel compactPanel" spacing="10" prefWidth="300" minWidth="300" maxWidth="300">
                        <Label text="Resumen" styleClass="cardTitle"/>
                        <HBox><Label text="Código:" style="-fx-text-fill: #000000;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblResCodigo" text="---" style="-fx-text-fill: #000000;"/></HBox>
                        <HBox><Label text="Proveedor:" style="-fx-text-fill: #000000;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblResProveedor" text="---" style="-fx-text-fill: #000000;"/></HBox>
                        <HBox><Label text="Fecha:" style="-fx-text-fill: #000000;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblResFecha" text="---" style="-fx-text-fill: #000000;"/></HBox>
                        <Separator/>
                        <HBox><Label text="Ingredientes:" style="-fx-text-fill: #000000;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblResItems" text="0" style="-fx-text-fill: #000000;"/></HBox>
                        <HBox><Label text="Total:" style="-fx-text-fill: #000000;"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblResTotal" text="RD$ 0.00" styleClass="cardTitle" style="-fx-text-fill: #27ae60;"/></HBox>
                    </VBox>
                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <Label text="Agregar ingredientes" styleClass="cardTitle"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ComboBox fx:id="cmbIngrediente" promptText="Ingrediente" prefWidth="250"/>
                        <TextField fx:id="txtCantidad" promptText="Cantidad" prefWidth="100"/>
                        <TextField fx:id="txtUnidad" promptText="Unidad" prefWidth="80"/>
                        <TextField fx:id="txtPrecioUnitario" promptText="Precio uni." prefWidth="120"/>
                        <Button text="+ Agregar" onAction="#agregarDetalle" styleClass="actionBlue"/>
                    </HBox>

                    <TableView fx:id="tablaDetalle" prefHeight="220" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Ingrediente" prefWidth="230"/>
                            <TableColumn text="Cantidad" prefWidth="100"/>
                            <TableColumn text="Unidad" prefWidth="80"/>
                            <TableColumn text="Precio uni." prefWidth="120"/>
                            <TableColumn text="Subtotal" prefWidth="130"/>
                            <TableColumn text="Acción" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label fx:id="lblTotalDetalle" text="Total: RD$ 0.00" styleClass="cardTitle" style="-fx-text-fill: #27ae60;"/>
                        <Button text="🗑 Quitar seleccionado" onAction="#quitarDetalle" styleClass="actionRed"/>
                    </HBox>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ PROVEEDORES ═══════════════ -->
            <ScrollPane fx:id="scrollProveedores" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Proveedores" styleClass="pageTitle"/>
                        <Label text="Registra y administra los proveedores del restaurante." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar" onAction="#guardarProveedor" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarProveedor" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Registro de proveedor" styleClass="cardTitle"/>
                    <GridPane hgap="20" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtIdProveedor" editable="false" promptText="Automático" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="RNC:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtRncProveedor" promptText="RNC o cédula" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombreProveedor" promptText="Nombre del proveedor (obligatorio)" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtTelefonoProveedor" promptText="Teléfono" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Dirección:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDireccionProveedor" promptText="Dirección principal" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Correo:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtCorreoProveedor" promptText="Correo electrónico" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        <Button text="💾 Guardar proveedor" onAction="#guardarProveedor" styleClass="actionGreen" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2" maxWidth="260"/>
                        <Button text="↻ Limpiar" onAction="#limpiarProveedor" styleClass="actionNeutral" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de proveedores" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="✎ Editar" onAction="#editarProveedor" styleClass="actionOrange"/>
                        <Button text="🗑 Eliminar" onAction="#eliminarProveedor" styleClass="actionRed"/>
                        <Button text="↻ Actualizar" onAction="#actualizarProveedores" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaProveedores" prefHeight="280" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="50"/>
                            <TableColumn text="Nombre" prefWidth="180"/>
                            <TableColumn text="RNC" prefWidth="120"/>
                            <TableColumn text="Teléfono" prefWidth="130"/>
                            <TableColumn text="Dirección" prefWidth="200"/>
                            <TableColumn text="Correo" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ RECEPCIÓN ═══════════════ -->
            <ScrollPane fx:id="scrollRecepcion" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Recepción de mercancía" styleClass="pageTitle"/>
                        <Label text="Valida la llegada de productos y procesa pagos a proveedores." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✔ Marcar recibida" onAction="#confirmarRecepcion" styleClass="actionGreen"/>
                    <Button text="💳 Procesar pago" onAction="#procesarPago" styleClass="actionBlue"/>
                    <Button text="↻ Actualizar" onAction="#recargarRecepcion" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="260" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Órdenes pendientes"/>
                        <Label fx:id="lblRecPendientes" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="260" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Recibidas hoy"/>
                        <Label fx:id="lblRecRecibidas" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="260" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Pendientes de pago"/>
                        <Label fx:id="lblRecPendientesPago" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <HBox spacing="16">
                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Seleccionar orden" styleClass="cardTitle"/>
                        <ComboBox fx:id="cmbOrdenRecepcion" promptText="Seleccionar orden pendiente" prefWidth="500" maxWidth="Infinity"/>

                        <GridPane hgap="16" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="220" prefWidth="220"/>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="220" prefWidth="220"/>
                            </columnConstraints>

                            <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtRecCodigo" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Proveedor:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtRecProveedor" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Fecha orden:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtRecFecha" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Estado:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtRecEstado" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Total orden:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtRecTotal" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Notas:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextArea fx:id="txtRecNotas" editable="false" prefRowCount="2" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel compactPanel" spacing="12" prefWidth="300" minWidth="300" maxWidth="300">
                        <Label text="Procesar pago" styleClass="cardTitle"/>
                        <Label text="Monto a pagar:"/>
                        <TextField fx:id="txtPagoMonto" promptText="0.00"/>
                        <Label text="Fecha pago:"/>
                        <DatePicker fx:id="datePago"/>
                        <Label text="Método de pago:"/>
                        <ComboBox fx:id="cmbMetodoPago" promptText="Seleccionar método" prefWidth="Infinity"/>
                        <Button text="💳 Procesar pago" onAction="#procesarPago" styleClass="actionBlue" maxWidth="Infinity" prefHeight="42"/>
                        <Button text="✔ Marcar como recibida" onAction="#confirmarRecepcion" styleClass="actionGreen" maxWidth="Infinity" prefHeight="42"/>
                    </VBox>
                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <Label text="Listado de órdenes" styleClass="cardTitle"/>
                    <TableView fx:id="tablaRecepcion" prefHeight="250" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="120"/>
                            <TableColumn text="Proveedor" prefWidth="200"/>
                            <TableColumn text="Fecha" prefWidth="130"/>
                            <TableColumn text="Total" prefWidth="130"/>
                            <TableColumn text="Estado" prefWidth="120"/>
                            <TableColumn text="Acciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
