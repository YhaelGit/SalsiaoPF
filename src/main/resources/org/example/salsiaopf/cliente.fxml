<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.ClienteController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage" fitWidth="82" fitHeight="82" preserveRatio="true"/>
            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Clientes" styleClass="brandSubtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>
            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>
                <Button fx:id="btnNotificaciones" text="🔔 0" onAction="#mostrarNotificaciones" styleClass="notificationModernButton"/>
                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="CLIENTES" styleClass="sideTitle"/>
            <Button text="📊  Dashboard" onAction="#mostrarDashboard" styleClass="sideButtonActive"/>
            <Button text="📋  Lista Clientes" onAction="#mostrarLista" styleClass="sideButton"/>
            <Button text="➕  Registrar" onAction="#mostrarRegistrar" styleClass="sideButton"/>
            <Button text="🛒  Historial Compras" onAction="#mostrarHistorial" styleClass="sideButton"/>
            <Button text="⭐  Clientes Frecuentes" onAction="#mostrarFrecuentes" styleClass="sideButton"/>
            <Button text="📅  Reservas" onAction="#mostrarReservas" styleClass="sideButton"/>
            <Button text="📍  Direcciones" onAction="#mostrarDirecciones" styleClass="sideButton"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="userCard">
                <Label text="Clientes" styleClass="userCardName"/>
                <Label text="Gestión comercial." wrapText="true" styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorClientes" styleClass="contentArea">

            <!-- ═══════════════ DASHBOARD ═══════════════ -->
            <ScrollPane fx:id="scrollDashboard" fitToWidth="true" fitToHeight="true" visible="true" managed="true" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Dashboard de Clientes" styleClass="pageTitle"/>
                        <Label text="Resumen general de la gestión de clientes." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtBuscarDashboard" promptText="🔍 Buscar cliente, cédula o teléfono..." prefWidth="350"/>
                    <Button text="Buscar" onAction="#buscarDashboard" styleClass="actionBlue"/>
                    <Button text="↻ Limpiar" onAction="#limpiarDashboard" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16" vgap="12">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="190" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Clientes registrados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalClientes" text="0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="190" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Clientes frecuentes" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblClientesFrecuentes" text="0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="190" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Nuevos del mes" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblNuevosMes" text="0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardPurple" prefWidth="190" prefHeight="85" GridPane.columnIndex="3">
                        <Label text="Pedidos realizados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalPedidos" text="0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardCyan" prefWidth="190" prefHeight="85" GridPane.columnIndex="4">
                        <Label text="Reservas" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalReservas" text="0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="190" prefHeight="85" GridPane.columnIndex="5">
                        <Label text="Mayor compra" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTopCompra" text="RD$ 0" style="-fx-text-fill: #000000; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                </GridPane>

                <VBox spacing="10" styleClass="cardPanel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Últimos clientes registrados" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Ver todos" onAction="#mostrarLista" styleClass="actionBlue"/>
                    </HBox>
                    <TableView fx:id="tablaDashboardClientes" prefHeight="280" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDashCodigo" text="Código" prefWidth="100"/>
                            <TableColumn fx:id="colDashNombre" text="Nombre completo" prefWidth="200"/>
                            <TableColumn fx:id="colDashTelefono" text="Teléfono" prefWidth="130"/>
                            <TableColumn fx:id="colDashTipo" text="Tipo" prefWidth="100"/>
                            <TableColumn fx:id="colDashUltimaCompra" text="Última compra" prefWidth="130"/>
                            <TableColumn fx:id="colDashEstado" text="Estado" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ LISTA CLIENTES ═══════════════ -->
            <ScrollPane fx:id="scrollLista" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Lista de Clientes" styleClass="pageTitle"/>
                        <Label text="Visualiza, busca y gestiona todos los clientes registrados." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtListaBuscar" promptText="🔍 Buscar nombre, cédula o teléfono..." prefWidth="300"/>
                    <Button text="🔍 Buscar" onAction="#buscarLista" styleClass="actionBlue"/>
                    <Button text="📋 Filtrar" onAction="#filtrarLista" styleClass="actionOrange"/>
                    <Button text="⇩ Exportar" onAction="#exportarLista" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarLista" styleClass="actionNeutral"/>
                </HBox>

                <VBox spacing="10" styleClass="cardPanel">
                    <HBox spacing="10">
                        <Button text="+ Nuevo" onAction="#nuevoCliente" styleClass="actionBlue"/>
                        <Button text="✎ Editar" onAction="#editarCliente" styleClass="actionOrange"/>
                        <Button text="🗑 Eliminar" onAction="#eliminarCliente" styleClass="actionRed"/>
                        <Button text="👁 Ver detalle" onAction="#verDetalleCliente" styleClass="actionBlue"/>
                        <Button text="💾 Guardar" onAction="#guardarListaCliente" styleClass="actionGreen"/>
                        <Button text="✖ Cancelar" onAction="#cancelarEdicion" styleClass="actionNeutral"/>
                    </HBox>
                </VBox>

                <GridPane hgap="14" vgap="10" styleClass="cardPanel">
                    <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtListaCodigo" editable="false" prefWidth="100" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtListaNombre" promptText="Nombre" prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                    <Label text="Apellido:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                    <TextField fx:id="txtListaApellido" promptText="Apellido" prefWidth="180" GridPane.rowIndex="0" GridPane.columnIndex="5"/>
                    <Label text="Cédula:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtListaCedula" promptText="Cédula" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtListaTelefono" promptText="Teléfono" prefWidth="150" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                    <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="4"/>
                    <TextField fx:id="txtListaEmail" promptText="Email" prefWidth="200" GridPane.rowIndex="1" GridPane.columnIndex="5"/>
                    <Label text="Dirección:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtListaDireccion" promptText="Dirección" prefWidth="250" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="2"/>
                    <Label text="Tipo:" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                    <ComboBox fx:id="cmbListaTipo" prefWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="4"/>
                    <Label text="Estado:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbListaEstado" prefWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtListaObservaciones" promptText="Observaciones" prefWidth="400" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="5"/>
                </GridPane>

                <VBox spacing="10" styleClass="cardPanel">
                    <TableView fx:id="tablaListaClientes" prefHeight="280" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colListaCodigo" text="Código" prefWidth="90"/>
                            <TableColumn fx:id="colListaNombre" text="Nombre" prefWidth="140"/>
                            <TableColumn fx:id="colListaApellido" text="Apellido" prefWidth="140"/>
                            <TableColumn fx:id="colListaCedula" text="Cédula" prefWidth="120"/>
                            <TableColumn fx:id="colListaTelefono" text="Teléfono" prefWidth="120"/>
                            <TableColumn fx:id="colListaDireccion" text="Dirección" prefWidth="180"/>
                            <TableColumn fx:id="colListaEmail" text="Email" prefWidth="160"/>
                            <TableColumn fx:id="colListaTipo" text="Tipo" prefWidth="100"/>
                            <TableColumn fx:id="colListaEstado" text="Estado" prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ REGISTRAR CLIENTE ═══════════════ -->
            <ScrollPane fx:id="scrollRegistrar" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Registrar Cliente" styleClass="pageTitle"/>
                        <Label text="Complete el formulario para agregar un nuevo cliente al sistema." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar" onAction="#guardarRegistro" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarRegistro" styleClass="actionNeutral"/>
                    <Button text="← Volver" onAction="#mostrarLista" styleClass="actionBlue"/>
                </HBox>

                <VBox spacing="14" styleClass="cardPanel">
                    <Label text="Datos del cliente" styleClass="cardTitle"/>
                    <GridPane hgap="18" vgap="14">
                        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtRegNombre" promptText="Ingrese nombre" prefWidth="240" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Apellido:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtRegApellido" promptText="Ingrese apellido" prefWidth="240" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                        <Label text="Cédula:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtRegCedula" promptText="Cédula o RNC" prefWidth="240" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtRegTelefono" promptText="Teléfono" prefWidth="240" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                        <Label text="Dirección:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtRegDireccion" promptText="Dirección" prefWidth="240" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                        <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtRegEmail" promptText="Email" prefWidth="240" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        <Label text="Tipo cliente:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbRegTipo" prefWidth="240" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                        <Label text="Observaciones:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtRegObservaciones" promptText="Notas u observaciones..." prefRowCount="3" wrapText="true" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ HISTORIAL COMPRAS ═══════════════ -->
            <ScrollPane fx:id="scrollHistorial" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Historial de Compras" styleClass="pageTitle"/>
                        <Label text="Consulta las compras realizadas por un cliente." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="👁 Ver detalle" onAction="#verDetalleHistorial" styleClass="actionBlue"/>
                    <Button text="⇩ Exportar" onAction="#exportarHistorial" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarHistorial" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="14" styleClass="cardPanel" HBox.hgrow="ALWAYS">
                        <Label text="Seleccionar cliente" styleClass="cardTitle"/>
                        <HBox spacing="10">
                            <ComboBox fx:id="cmbHistorialCliente" promptText="Seleccione un cliente..." prefWidth="350"/>
                            <Button text="🔍 Buscar" onAction="#cargarHistorial" styleClass="actionBlue"/>
                            <Button text="📋 Filtrar" onAction="#filtrarHistorial" styleClass="actionOrange"/>
                        </HBox>
                    </VBox>
                    <VBox spacing="8" styleClass="cardPanel" prefWidth="300">
                        <Label text="Resumen" styleClass="cardTitle"/>
                        <Label fx:id="lblHistTotalCompras" text="Total compras: 0"/>
                        <Label fx:id="lblHistMontoTotal" text="Monto total: RD$ 0.00"/>
                    </VBox>
                </HBox>

                <VBox spacing="10" styleClass="cardPanel">
                    <TableView fx:id="tablaHistorialCompras" prefHeight="350" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHistFecha" text="Fecha" prefWidth="120"/>
                            <TableColumn fx:id="colHistPedido" text="N° Pedido" prefWidth="140"/>
                            <TableColumn fx:id="colHistTotal" text="Total" prefWidth="130"/>
                            <TableColumn fx:id="colHistMetodo" text="Método de pago" prefWidth="160"/>
                            <TableColumn fx:id="colHistEstado" text="Estado" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ CLIENTES FRECUENTES ═══════════════ -->
            <ScrollPane fx:id="scrollFrecuentes" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Clientes Frecuentes" styleClass="pageTitle"/>
                        <Label text="Identifica los clientes con más compras en el sistema." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtFrecBuscar" promptText="🔍 Buscar cliente..." prefWidth="300"/>
                    <Button text="🔍 Buscar" onAction="#buscarFrecuentes" styleClass="actionBlue"/>
                    <Button text="📋 Filtrar" onAction="#filtrarFrecuentes" styleClass="actionOrange"/>
                    <Button text="⇩ Exportar" onAction="#exportarFrecuentes" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFrecuentes" styleClass="actionNeutral"/>
                </HBox>

                <VBox spacing="10" styleClass="cardPanel">
                    <HBox spacing="10">
                        <Button text="👁 Ver detalle" onAction="#verDetalleFrecuente" styleClass="actionBlue"/>
                    </HBox>
                    <TableView fx:id="tablaFrecuentes" prefHeight="400" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFrecCodigo" text="Código" prefWidth="100"/>
                            <TableColumn fx:id="colFrecNombre" text="Nombre" prefWidth="200"/>
                            <TableColumn fx:id="colFrecCompras" text="Cant. compras" prefWidth="130"/>
                            <TableColumn fx:id="colFrecTotal" text="Total gastado" prefWidth="150"/>
                            <TableColumn fx:id="colFrecUltimaCompra" text="Última compra" prefWidth="140"/>
                            <TableColumn fx:id="colFrecEstado" text="Estado" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ RESERVAS ═══════════════ -->
            <ScrollPane fx:id="scrollReservas" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Reservas" styleClass="pageTitle"/>
                        <Label text="Administra las reservas realizadas por los clientes." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nueva reserva" onAction="#nuevaReserva" styleClass="actionBlue"/>
                    <Button text="👁 Ver detalle" onAction="#verDetalleReserva" styleClass="actionBlue"/>
                    <Button text="🗙 Cancelar reserva" onAction="#cancelarReserva" styleClass="actionRed"/>
                    <Button text="⇩ Exportar" onAction="#exportarReservas" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarReservas" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="14" styleClass="cardPanel" HBox.hgrow="ALWAYS">
                        <Label text="Datos de la reserva" styleClass="cardTitle"/>
                        <GridPane hgap="14" vgap="12">
                            <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbReservaCliente" promptText="Seleccione cliente..." prefWidth="250" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Fecha:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <DatePicker fx:id="dpReservaFecha" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                            <Label text="Hora:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtReservaHora" promptText="19:30" prefWidth="120" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Personas:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <Spinner fx:id="spReservaPersonas" prefWidth="120" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                            <Label text="Estado:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbReservaEstado" prefWidth="180" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Observaciones:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtReservaObservaciones" promptText="Notas..." prefWidth="400" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                        </GridPane>
                        <HBox spacing="10">
                            <Button text="💾 Guardar" onAction="#guardarReserva" styleClass="actionGreen"/>
                            <Button text="✖ Cancelar" onAction="#cancelarEdicionReserva" styleClass="actionNeutral"/>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox spacing="10" styleClass="cardPanel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Lista de reservas" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtReservaBuscar" promptText="🔍 Buscar reserva..." prefWidth="240"/>
                        <Button text="🔍" onAction="#buscarReservas" styleClass="actionBlue"/>
                    </HBox>
                    <TableView fx:id="tablaReservas" prefHeight="250" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colResCodigo" text="Código" prefWidth="100"/>
                            <TableColumn fx:id="colResCliente" text="Cliente" prefWidth="180"/>
                            <TableColumn fx:id="colResFecha" text="Fecha" prefWidth="120"/>
                            <TableColumn fx:id="colResHora" text="Hora" prefWidth="90"/>
                            <TableColumn fx:id="colResPersonas" text="Personas" prefWidth="90"/>
                            <TableColumn fx:id="colResEstado" text="Estado" prefWidth="110"/>
                            <TableColumn fx:id="colResObservaciones" text="Observaciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ DIRECCIONES ═══════════════ -->
            <ScrollPane fx:id="scrollDirecciones" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Direcciones / Delivery" styleClass="pageTitle"/>
                        <Label text="Administra las direcciones de entrega de los clientes." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo" onAction="#nuevaDireccion" styleClass="actionBlue"/>
                    <Button text="✎ Editar" onAction="#editarDireccion" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" onAction="#eliminarDireccion" styleClass="actionRed"/>
                    <Button text="💾 Guardar" onAction="#guardarDireccion" styleClass="actionGreen"/>
                    <Button text="✖ Cancelar" onAction="#cancelarEdicionDireccion" styleClass="actionNeutral"/>
                    <Button text="↻ Limpiar" onAction="#limpiarDirecciones" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="14" styleClass="cardPanel" HBox.hgrow="ALWAYS">
                        <Label text="Datos de la dirección" styleClass="cardTitle"/>
                        <GridPane hgap="14" vgap="12">
                            <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbDirCliente" promptText="Seleccione cliente..." prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Dirección:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtDirDireccion" promptText="Dirección de entrega" prefWidth="350" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="2"/>
                            <Label text="Referencia:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtDirReferencia" promptText="Referencia" prefWidth="250" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Zona:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtDirZona" promptText="Zona" prefWidth="180" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                            <Label text="Teléfono:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtDirTelefono" promptText="Teléfono" prefWidth="200" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>
                </HBox>

                <VBox spacing="10" styleClass="cardPanel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Lista de direcciones" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtDirBuscar" promptText="🔍 Buscar dirección..." prefWidth="240"/>
                        <Button text="🔍" onAction="#buscarDirecciones" styleClass="actionBlue"/>
                        <Button text="📋 Filtrar" onAction="#filtrarDirecciones" styleClass="actionOrange"/>
                    </HBox>
                    <TableView fx:id="tablaDirecciones" prefHeight="300" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDirCliente" text="Cliente" prefWidth="200"/>
                            <TableColumn fx:id="colDirDireccion" text="Dirección" prefWidth="250"/>
                            <TableColumn fx:id="colDirReferencia" text="Referencia" prefWidth="180"/>
                            <TableColumn fx:id="colDirZona" text="Zona" prefWidth="130"/>
                            <TableColumn fx:id="colDirTelefono" text="Teléfono" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
