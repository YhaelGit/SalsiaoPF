<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.ClienteController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Clientes" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="☰ Volver"
                    onAction="#volverMenu"
                    styleClass="topButton"/>

            <HBox alignment="CENTER" spacing="10">

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 0"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>

                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>

            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="CLIENTE" styleClass="sideTitle"/>

            <Button fx:id="btnRegistro" text="👤  Registro del cliente" onAction="#mostrarRegistro" styleClass="sideButtonActive"/>
            <Button fx:id="btnReservas" text="📅  Reservas" onAction="#mostrarReservas" styleClass="sideButton"/>
            <Button fx:id="btnReclamaciones" text="❗  Reclamaciones" onAction="#mostrarReclamaciones" styleClass="sideButton"/>
            <Button fx:id="btnHistorial" text="↺  Historial del cliente" onAction="#mostrarHistorial" styleClass="sideButton"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="userCard">
                <Label text="Clientes"
                       styleClass="userCardName"/>

                <Label text="Gestión del cliente."
                       wrapText="true"
                       styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorCliente" styleClass="contentArea">

            <!-- REGISTRO -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewRegistro" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Registro del cliente" styleClass="pageTitle"/>
                        <Label text="Administra los datos personales y direcciones del cliente." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" styleClass="actionRed"/>
                    <Button text="💾 Guardar" onAction="#guardarCliente" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarRegistroCliente" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="14">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del cliente" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints minWidth="70" prefWidth="70"/>
                                <ColumnConstraints hgrow="ALWAYS"/>

                                <ColumnConstraints minWidth="100" prefWidth="100"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="ID Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" prefWidth="240"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Fecha de registro:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField promptText="Automático" editable="false" prefWidth="240"
                                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombre" promptText="Ingrese nombre" prefWidth="240"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Apellido:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtApellido" promptText="Ingrese apellido" prefWidth="240"
                                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtTelefono" promptText="Ingrese teléfono" prefWidth="240"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField promptText="Email opcional" prefWidth="240"
                                       GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="14" prefWidth="470">
                        <Label text="Búsqueda rápida" styleClass="cardTitle"/>

                        <HBox spacing="10">
                            <ComboBox fx:id="cmbTipoBusqueda" promptText="Nombre" prefWidth="130"/>
                            <TextField fx:id="txtBuscarCliente" promptText="Ingrese texto a buscar" HBox.hgrow="ALWAYS"/>
                            <Button text="🔍 Buscar" styleClass="actionBlue"/>
                        </HBox>

                        <Label text="Seleccione un cliente de la tabla para ver o editar su información."
                               wrapText="true"
                               style="-fx-background-color:#e8f6e8; -fx-padding:16; -fx-background-radius:8; -fx-text-fill:#14532d;"/>
                    </VBox>
                </HBox>

                <VBox styleClass="cardPanel" spacing="10">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Direcciones del cliente" styleClass="cardTitle"/>
                        <Button text="+ Agregar dirección" styleClass="actionGreen"/>
                        <Button text="Quitar dirección seleccionada" styleClass="actionRed"/>
                    </HBox>

                    <GridPane hgap="10" vgap="10">
                        <Label text="Tipo:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbTipoDireccion" promptText="Casa" prefWidth="150" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Dirección:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtDireccion" promptText="Ingrese dirección" prefWidth="420" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Referencia:" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                        <TextField fx:id="txtReferenciaDireccion" promptText="Referencia" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="5"/>
                    </GridPane>

                    <TableView fx:id="tablaDirecciones" prefHeight="140" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDireccionId" text="ID" prefWidth="100"/>
                            <TableColumn fx:id="colDireccionTipo" text="Tipo" prefWidth="130"/>
                            <TableColumn fx:id="colDireccionNombre" text="Dirección" prefWidth="450"/>
                            <TableColumn fx:id="colDireccionPrincipal" text="Principal" prefWidth="200"/>
                            <TableColumn fx:id="colReferencia" text="Referencia" prefWidth="200"/>
                        </columns>
                    </TableView>

                    <Label text="* Puede establecer una sola dirección como principal." styleClass="pageSubtitle"/>
                </VBox>

                <VBox styleClass="cardPanel" spacing="10">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de clientes" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="↻ Actualizar" onAction="#cargarClientes" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaClientes" prefHeight="260" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colIdCliente" text="ID Cliente" prefWidth="130"/>
                            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="150"/>
                            <TableColumn fx:id="colApellido" text="Apellido" prefWidth="150"/>
                            <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="180"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="260"/>
                            <TableColumn fx:id="colFechaRegistro" text="Fecha de registro" prefWidth="200"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mostrando clientes registrados" styleClass="pageSubtitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="&lt;&lt;" styleClass="actionNeutral"/>
                        <Button text="&lt;" styleClass="actionNeutral"/>
                        <Button text="1" styleClass="actionBlue"/>
                        <Button text="&gt;" styleClass="actionNeutral"/>
                        <Button text="&gt;&gt;" styleClass="actionNeutral"/>
                        <ComboBox promptText="10 por página" prefWidth="150"/>
                    </HBox>
                </VBox>

            </VBox>

            </VBox>
            </ScrollPane>

            <!-- RESERVAS -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewReservas" styleClass="content" spacing="16">

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="12">

                    <VBox>
                        <Label text="Reservas" styleClass="pageTitle"/>
                        <Label text="Administra las reservas de los clientes."
                               styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva reserva" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗙 Cancelar reserva" styleClass="actionRed"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>

                </HBox>

                <!-- PANEL SUPERIOR -->
                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de la reserva" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="12">

                            <columnConstraints>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                                <ColumnConstraints minWidth="150" prefWidth="150"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                            </columnConstraints>

                            <Label text="ID Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField promptText="Nombre del cliente" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField promptText="Teléfono cliente" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Cantidad personas:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <Spinner prefWidth="160" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Mesa:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <ComboBox promptText="Mesa disponible" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Estado:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Estado" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Fecha:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <DatePicker GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Hora:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <TextField promptText="07:30 PM" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Motivo / ocasión:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <ComboBox promptText="Motivo" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Solicitud especial:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextArea promptText="Ejemplo: mesa cerca de la ventana, sin picante, silla para niño..."
                                      prefRowCount="3"
                                      wrapText="true"
                                      GridPane.rowIndex="5"
                                      GridPane.columnIndex="1"
                                      GridPane.columnSpan="3"/>

                            <Label text="Creada por:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <TextField promptText="Usuario" editable="false" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                            <Label text="Fecha registro:" GridPane.rowIndex="6" GridPane.columnIndex="2"/>
                            <TextField promptText="Automático" editable="false" GridPane.rowIndex="6" GridPane.columnIndex="3"/>

                        </GridPane>
                    </VBox>

                    <!-- PANEL DERECHO -->
                    <VBox spacing="16"
                          prefWidth="360">

                        <!-- ACCIONES -->
                        <VBox spacing="12">
                            <Button text="Ver disponibilidad"
                                    wrapText="true"
                                    textAlignment="CENTER"
                                    prefWidth="260"
                                    prefHeight="52"
                                    styleClass="actionBlue"/>

                            <Button text="Imprimir reserva"
                                    wrapText="true"
                                    textAlignment="CENTER"
                                    prefWidth="260"
                                    prefHeight="52"
                                    styleClass="actionGreen"/>
                        </VBox>

                        <!-- ESTADO -->
                        <VBox spacing="12"
                              styleClass="cardPanel">

                            <Label text="Estado de reservas"
                                   styleClass="cardTitle"/>

                            <HBox>
                                <Label text="Confirmadas"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="12"/>
                            </HBox>

                            <HBox>
                                <Label text="Pendientes"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="5"/>
                            </HBox>

                            <HBox>
                                <Label text="Canceladas"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="2"/>
                            </HBox>

                            <HBox>
                                <Label text="Completadas"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="18"/>
                            </HBox>

                        </VBox>

                    </VBox>

                </HBox>

                <!-- TABLA -->
                <VBox spacing="12"
                      styleClass="cardPanel">

                    <HBox alignment="CENTER_LEFT">

                        <Label text="Lista de reservas"
                               styleClass="cardTitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="📅 Rango fechas"
                                styleClass="actionNeutral"/>

                        <ComboBox promptText="Estado: Todos"
                                  prefWidth="170"/>

                        <TextField promptText="Buscar reserva..."
                                   prefWidth="240"/>

                        <Button text="↻"
                                styleClass="actionNeutral"/>

                    </HBox>

                    <TableView fx:id="tablaReservas"
                               prefHeight="320" VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn text="ID Reserva"
                                         prefWidth="90"/>

                            <TableColumn text="Cliente"
                                         prefWidth="150"/>

                            <TableColumn text="Mesa"
                                         prefWidth="100"/>

                            <TableColumn text="Fecha/Hora"
                                         prefWidth="140"/>

                            <TableColumn text="Personas"
                                         prefWidth="100"/>

                            <TableColumn text="Estado"
                                         prefWidth="100"/>

                            <TableColumn text="Motivo"
                                         prefWidth="200"/>

                            <TableColumn text="Creada por"
                                         prefWidth="120"/>

                            <TableColumn text="Solicitudes"
                                         prefWidth="150"/>
                        </columns>

                    </TableView>

                    <HBox alignment="CENTER_LEFT">

                        <Label text="Mostrando reservas registradas"
                               styleClass="pageSubtitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="&lt;&lt;"
                                styleClass="actionNeutral"/>

                        <Button text="&lt;"
                                styleClass="actionNeutral"/>

                        <Button text="1"
                                styleClass="actionBlue"/>

                        <Button text="2"
                                styleClass="actionNeutral"/>

                        <Button text="3"
                                styleClass="actionNeutral"/>

                        <Button text="&gt;"
                                styleClass="actionNeutral"/>

                        <Button text="&gt;&gt;"
                                styleClass="actionNeutral"/>

                        <ComboBox promptText="10 por página"
                                  prefWidth="150"/>

                    </HBox>

                </VBox>

            </VBox>

            </VBox>
            </ScrollPane>

            <!-- RECLAMACIONES -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewReclamaciones" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Reclamaciones" styleClass="pageTitle"/>
                        <Label text="Gestiona las reclamaciones realizadas por los clientes." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva reclamación" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="☑ Resolver" styleClass="actionGreen"/>
                    <Button text="☒ Cancelar" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">

                        <Label text="Datos de la reclamación"
                               styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="12">

                            <columnConstraints>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="240" prefWidth="240"/>

                                <ColumnConstraints minWidth="150" prefWidth="150"/>
                                <ColumnConstraints minWidth="240" prefWidth="240"/>
                            </columnConstraints>

                            <!-- FILA 1 -->

                            <Label text="ID Cliente:"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>

                            <TextField promptText="Automático"
                                       editable="false"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                            <Label text="Cliente:"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="2"/>

                            <TextField promptText="Nombre del cliente"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="3"/>

                            <!-- FILA 2 -->

                            <Label text="Pedido / Factura:"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>

                            <TextField promptText="Factura o pedido"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                            <Label text="Empleado atiende:"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="2"/>

                            <TextField promptText="Empleado responsable"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="3"/>

                            <!-- FILA 3 -->

                            <Label text="Fecha:"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>

                            <DatePicker GridPane.rowIndex="2"
                                        GridPane.columnIndex="1"/>

                            <Label text="Estado:"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="2"/>

                            <ComboBox promptText="Estado"
                                      GridPane.rowIndex="2"
                                      GridPane.columnIndex="3"/>

                            <!-- FILA 4 -->

                            <Label text="Motivo:"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="0"/>

                            <TextField promptText="Explique el motivo de la reclamación"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="1"
                                       GridPane.columnSpan="3"/>

                            <!-- FILA 5 -->

                            <Label text="Tipo devolución:"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="0"/>

                            <ComboBox promptText="Sin devolución"
                                      GridPane.rowIndex="4"
                                      GridPane.columnIndex="1"/>

                            <Label text="Monto devolución:"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="2"/>

                            <TextField promptText="0.00"
                                       GridPane.rowIndex="4"
                                       GridPane.columnIndex="3"/>

                            <!-- FILA 6 -->

                            <Label text="Adjuntos:"
                                   GridPane.rowIndex="5"
                                   GridPane.columnIndex="0"/>

                            <HBox spacing="10"
                                  GridPane.rowIndex="5"
                                  GridPane.columnIndex="1"
                                  GridPane.columnSpan="3">

                                <Button text="Seleccionar archivo"
                                        styleClass="actionBlue"/>

                                <Label text="Ningún archivo seleccionado"/>

                            </HBox>

                            <!-- FILA 7 -->

                            <Label text="Creada por:"
                                   GridPane.rowIndex="6"
                                   GridPane.columnIndex="0"/>

                            <TextField promptText="Usuario"
                                       editable="false"
                                       GridPane.rowIndex="6"
                                       GridPane.columnIndex="1"/>

                            <Label text="Fecha registro:"
                                   GridPane.rowIndex="6"
                                   GridPane.columnIndex="2"/>

                            <TextField promptText="Automático"
                                       editable="false"
                                       GridPane.rowIndex="6"
                                       GridPane.columnIndex="3"/>

                        </GridPane>

                    </VBox>

                    <VBox spacing="16" prefWidth="390">
                        <VBox spacing="12" styleClass="cardPanel">
                            <Label text="Resumen de reclamaciones" styleClass="cardTitle"/>

                            <GridPane hgap="12" vgap="12">
                                <VBox alignment="CENTER" spacing="6" styleClass="statusCardOrange" prefWidth="165" prefHeight="95"
                                      GridPane.rowIndex="0" GridPane.columnIndex="0">
                                    <Label text="Pendientes"/>
                                    <Label text="5" styleClass="metricValueSmall"/>
                                </VBox>

                                <VBox alignment="CENTER" spacing="6" styleClass="statusCardGreen" prefWidth="165" prefHeight="95"
                                      GridPane.rowIndex="0" GridPane.columnIndex="1">
                                    <Label text="Resueltas"/>
                                    <Label text="12" styleClass="metricValueSmall"/>
                                </VBox>

                                <VBox alignment="CENTER" spacing="6" styleClass="statusCardRed" prefWidth="165" prefHeight="95"
                                      GridPane.rowIndex="1" GridPane.columnIndex="0">
                                    <Label text="Canceladas"/>
                                    <Label text="2" styleClass="metricValueSmall"/>
                                </VBox>

                                <VBox alignment="CENTER" spacing="6" styleClass="statusCardBlue" prefWidth="165" prefHeight="95"
                                      GridPane.rowIndex="1" GridPane.columnIndex="1">
                                    <Label text="En revisión"/>
                                    <Label text="3" styleClass="metricValueSmall"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox styleClass="cardPanel" spacing="12" prefWidth="320">
                            <Label text="Acciones rápidas" styleClass="cardTitle"/>

                            <VBox spacing="10">
                                <Button text="Generar devolución"
                                        wrapText="true"
                                        textAlignment="CENTER"
                                        prefWidth="260"
                                        prefHeight="48"
                                        styleClass="actionBlue"/>

                                <Button text="Ver devoluciones"
                                        wrapText="true"
                                        textAlignment="CENTER"
                                        prefWidth="260"
                                        prefHeight="48"
                                        styleClass="actionGreen"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>

                <VBox spacing="12" styleClass="cardPanel">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Lista de reclamaciones" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="📅 Rango fechas" styleClass="actionNeutral"/>
                        <ComboBox promptText="Estado: Todos" prefWidth="170"/>
                        <TextField promptText="Buscar reclamación..." prefWidth="240"/>
                        <Button text="↻" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaReclamaciones" prefHeight="285" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID Reclamación" prefWidth="120"/>
                            <TableColumn text="Cliente" prefWidth="130"/>
                            <TableColumn text="Pedido / Factura" prefWidth="120"/>
                            <TableColumn text="Fecha" prefWidth="120"/>
                            <TableColumn text="Motivo" prefWidth="220"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Tipo devolución" prefWidth="130"/>
                            <TableColumn text="Monto devolución" prefWidth="120"/>
                            <TableColumn text="Empleado" prefWidth="100"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mostrando reclamaciones registradas" styleClass="pageSubtitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="&lt;&lt;" styleClass="actionNeutral"/>
