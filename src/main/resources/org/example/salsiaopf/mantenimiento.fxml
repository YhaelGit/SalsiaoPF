<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.MantenimientoController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Mantenimiento" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>

            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 0"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">

            <Label text="MANTENIMIENTO"
                   styleClass="sideTitle"/>

            <Button fx:id="btnEquipos"
                    text="🛠  Equipos"
                    onAction="#mostrarEquipos"
                    styleClass="sideButton"/>

            <Button fx:id="btnFallos"
                    text="⚠  Fallos"
                    onAction="#mostrarFallos"
                    styleClass="sideButton"/>

            <Button fx:id="btnReparaciones"
                    text="🔧  Reparaciones"
                    onAction="#mostrarReparaciones"
                    styleClass="sideButton"/>

            <Button fx:id="btnLimpieza"
                    text="🧹  Limpieza"
                    onAction="#mostrarLimpieza"
                    styleClass="sideButton"/>

            <Button fx:id="btnHistorialMantenimiento"
                    text="↺  Historial"
                    onAction="#mostrarHistorialMantenimiento"
                    styleClass="sideButton"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="userCard">
                <Label text="Mantenimiento"
                       styleClass="userCardName"/>

                <Label text="Gestión del mantenimiento."
                       wrapText="true"
                       styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorMantenimiento"
                   styleClass="contentArea">

            <!-- EQUIPOS -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewEquipos" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Equipos" styleClass="pageTitle"/>
                        <Label text="Administra equipos, máquinas, utensilios y activos operativos del restaurante." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo equipo" onAction="#nuevoEquipo" styleClass="actionBlue"/>
                    <Button text="✎ Editar" onAction="#editarEquipo" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" onAction="#eliminarEquipo" styleClass="actionRed"/>
                    <Button text="💾 Guardar" onAction="#guardarEquipo" styleClass="actionGreen"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del equipo" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Maquina:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Área:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Seleccionar área" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Nombre:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField promptText="Nevera, freidora, estufa..." prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Tipo:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Tipo de equipo"
                                      prefWidth="260"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="3"/>

                            <Label text="Marca:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField promptText="Marca" prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Modelo:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField promptText="Modelo" prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox promptText="Estado"
                                      prefWidth="260"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"/>
                            <Label text="Fecha compra:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <DatePicker prefWidth="260" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Observación:" minWidth="140" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextArea promptText="Observaciones del equipo..." prefRowCount="3" prefWidth="260"
                                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="12" prefWidth="390">
                        <Label text="Resumen equipos" styleClass="cardTitle"/>

                        <HBox><Label text="Activos:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="En reparación:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Fuera servicio:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Mantenimientos pendientes:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>

                        <Separator/>

                        <Button text="Registrar fallo" onAction="#registrarFallo" styleClass="actionOrange" prefHeight="42"/>
                        <Button text="Ver historial equipo" onAction="#verHistorialEquipo" styleClass="actionBlue" prefHeight="42"/>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de equipos" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox promptText="Estado" prefWidth="160"/>
                        <TextField promptText="Buscar equipo..." prefWidth="240"/>
                        <Button text="🔍" onAction="#buscarEquipo" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView prefHeight="430" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="90"/>
                            <TableColumn text="Equipo" prefWidth="240"/>
                            <TableColumn text="Área" prefWidth="180"/>
                            <TableColumn text="Tipo" prefWidth="180"/>
                            <TableColumn text="Marca" prefWidth="150"/>
                            <TableColumn text="Modelo" prefWidth="150"/>
                            <TableColumn text="Estado" prefWidth="160"/>
                            <TableColumn text="Último mantenimiento" prefWidth="200"/>
                            <TableColumn text="Acciones" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- FALLOS -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewFallos" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">

                    <VBox>
                        <Label text="Fallos"
                               styleClass="pageTitle"/>

                        <Label text="Registra daños, averías y problemas operativos detectados en equipos o áreas."
                               styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Registrar fallo"
                            onAction="#registrarFallo"
                            styleClass="actionBlue"/>

                    <Button text="✎ Editar"
                            onAction="#editarFallo"
                            styleClass="actionOrange"/>

                    <Button text="✔ Resolver"
                            onAction="#resolverFallo"
                            styleClass="actionGreen"/>

                    <Button text="🗑 Eliminar"
                            onAction="#eliminarFallo"
                            styleClass="actionRed"/>

                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel"
                          spacing="14"
                          HBox.hgrow="ALWAYS">

                        <Label text="Datos del fallo"
                               styleClass="cardTitle"/>

                        <GridPane hgap="18"
                                  vgap="14">

                            <Label text="ID Fallo:"
                                   minWidth="140"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="0"/>

                            <TextField promptText="Automático"
                                       editable="false"
                                       prefWidth="260"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                            <Label text="Equipo:"
                                   minWidth="140"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="2"/>

                            <ComboBox promptText="Seleccionar equipo"
                                      prefWidth="260"
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="3"/>

                            <Label text="Área:"
                                   minWidth="140"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="0"/>

                            <ComboBox promptText="Área afectada"
                                      prefWidth="260"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="1"/>

                            <Label text="Estado:"
                                   minWidth="140"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="0"/>

                            <ComboBox promptText="Pendiente / En proceso / Resuelto"
                                      prefWidth="260"
                                      GridPane.rowIndex="2"
                                      GridPane.columnIndex="1"/>

                            <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <DatePicker GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Descripción:"
                                   minWidth="140"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="0"/>

                            <TextArea promptText="Describir el fallo..."
                                      prefRowCount="4"
                                      prefWidth="260"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"/>

                        </GridPane>

                    </VBox>

                    <VBox styleClass="cardPanel"
                          spacing="12"
                          prefWidth="390">

                        <Label text="Resumen fallos"
                               styleClass="cardTitle"/>

                        <HBox>
                            <Label text="Pendientes"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <HBox>
                            <Label text="En proceso"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <HBox>
                            <Label text="Resueltos"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <HBox>
                            <Label text="Alta prioridad"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="0"/>
                        </HBox>

                        <Separator/>

                        <Button text="Ver reparaciones"
                                onAction="#mostrarReparaciones"
                                styleClass="actionBlue"
                                prefHeight="42"/>

                        <Button text="Generar reporte"
                                onAction="#generarReporteFallos"
                                styleClass="actionOrange"
                                prefHeight="42"/>

                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel"
                      spacing="12">

                    <HBox alignment="CENTER_LEFT">

                        <Label text="Listado de fallos"
                               styleClass="cardTitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <TextField promptText="Buscar fallo..."
                                   prefWidth="240"/>

                        <Button text="🔍"
                                onAction="#buscarFallo"
                                styleClass="actionNeutral"/>

                    </HBox>

                    <TableView prefHeight="430" VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn text="ID"
                                         prefWidth="90"/>

                            <TableColumn text="Equipo"
                                         prefWidth="200"/>

                            <TableColumn text="Área"
                                         prefWidth="120"/>

                            <TableColumn text="Estado"
                                         prefWidth="100"/>

                            <TableColumn text="Fecha"
                                         prefWidth="110"/>

                            <TableColumn text="Descripción"
                                         prefWidth="250"/>

                            <TableColumn text="Acciones"
                                         prefWidth="160"/>

                        </columns>

                    </TableView>

                </VBox>

            </VBox>
            </ScrollPane>

            <!-- REPARACIONES -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewReparaciones" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Reparaciones" styleClass="pageTitle"/>
                        <Label text="Controla reparaciones, técnicos, costos y estado de solución." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva reparación" onAction="#nuevaReparacion" styleClass="actionBlue"/>
                    <Button text="✎ Editar" onAction="#editarReparacion" styleClass="actionOrange"/>
                    <Button text="✔ Finalizar" onAction="#finalizarReparacion" styleClass="actionGreen"/>
                    <Button text="🗑 Eliminar" onAction="#eliminarReparacion" styleClass="actionRed"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de reparación" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Reparación:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Fallo:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Seleccionar fallo" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Equipo:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField promptText="Equipo afectado" editable="false" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Técnico:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Seleccionar técnico" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Fecha inicio:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <DatePicker prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Fecha final:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <DatePicker prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Costo:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField promptText="0.00" prefWidth="260" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Pendiente / En proceso / Finalizada" prefWidth="260" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Descripción:" minWidth="140" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextArea promptText="Trabajo realizado o diagnóstico..." prefRowCount="4" prefWidth="260"
                                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="12" prefWidth="390">
                        <Label text="Resumen reparaciones" styleClass="cardTitle"/>

                        <HBox><Label text="Pendientes"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="En proceso"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Finalizadas"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Costo del mes"/><Region HBox.hgrow="ALWAYS"/><Label text="RD$ 0.00"/></HBox>

                        <Separator/>

                        <Button text="Ver fallos pendientes" onAction="#mostrarFallos" styleClass="actionBlue" prefHeight="42"/>
                        <Button text="Generar orden técnica" onAction="#generarOrdenTecnica" styleClass="actionOrange" prefHeight="42"/>
                        <Button text="Finalizar reparación" onAction="#finalizarReparacion" styleClass="actionGreen" prefHeight="42"/>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de reparaciones" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox promptText="Estado" prefWidth="160"/>
                        <ComboBox promptText="Técnico" prefWidth="180"/>
                        <TextField promptText="Buscar reparación..." prefWidth="240"/>
                        <Button text="🔍" onAction="#buscarReparacion" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView prefHeight="430" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="90"/>
                            <TableColumn text="Fallo" prefWidth="120"/>
                            <TableColumn text="Equipo" prefWidth="220"/>
                            <TableColumn text="Técnico" prefWidth="140"/>
                            <TableColumn text="Fecha inicio" prefWidth="150"/>
                            <TableColumn text="Fecha final" prefWidth="150"/>
                            <TableColumn text="Costo" prefWidth="110"/>
                            <TableColumn text="Estado" prefWidth="150"/>
                            <TableColumn text="Acciones" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- LIMPIEZA -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewLimpieza" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Limpieza" styleClass="pageTitle"/>
                        <Label text="Controla tareas de limpieza, áreas asignadas, responsables y frecuencia." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nueva tarea" onAction="#nuevaTareaLimpieza" styleClass="actionBlue"/>
                    <Button text="✎ Editar" onAction="#editarTareaLimpieza" styleClass="actionOrange"/>
                    <Button text="✔ Completar" onAction="#completarTareaLimpieza" styleClass="actionGreen"/>
                    <Button text="🗑 Eliminar" onAction="#eliminarTareaLimpieza" styleClass="actionRed"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de limpieza" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Maquina:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Automático" editable="false" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Área:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Seleccionar área" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Responsable:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <ComboBox promptText="Empleado responsable" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Frecuencia:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Diaria / Semanal / Mensual" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Fecha:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <DatePicker prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Pendiente / Completada" prefWidth="260" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Descripción:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextArea promptText="Descripción de la tarea..."
                                      prefRowCount="4"
                                      prefWidth="260"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="1"/>

                            <Label text="Observación:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <TextArea promptText="Observación final..."
                                      prefRowCount="4"
                                      prefWidth="260"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="12" prefWidth="390">
                        <Label text="Resumen limpieza" styleClass="cardTitle"/>

                        <HBox><Label text="Pendientes"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Completadas hoy"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Áreas críticas"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        <HBox><Label text="Responsables activos"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>

                        <Separator/>

                        <Button text="Ver tareas pendientes" onAction="#mostrarLimpieza" styleClass="actionBlue" prefHeight="42"/>
                        <Button text="Generar rutina diaria" onAction="#generarRutinaDiaria" styleClass="actionOrange" prefHeight="42"/>
                        <Button text="Marcar completada" onAction="#completarTareaLimpieza" styleClass="actionGreen" prefHeight="42"/>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de tareas de limpieza" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox promptText="Área" prefWidth="180"/>
                        <ComboBox promptText="Estado" prefWidth="160"/>
                        <TextField promptText="Buscar tarea..." prefWidth="240"/>
                        <Button text="🔍" onAction="#buscarTareaLimpieza" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView prefHeight="430" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="90"/>
                            <TableColumn text="Área" prefWidth="120"/>
                            <TableColumn text="Responsable" prefWidth="130"/>
                            <TableColumn text="Frecuencia" prefWidth="120"/>
                            <TableColumn text="Fecha" prefWidth="140"/>
                            <TableColumn text="Estado" prefWidth="150"/>
                            <TableColumn text="Descripción" prefWidth="360"/>
                            <TableColumn text="Acciones" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- HISTORIAL -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewHistorialMantenimiento" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Historial mantenimiento" styleClass="pageTitle"/>
                        <Label text="Consulta fallos, reparaciones, limpiezas y mantenimientos registrados." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="📄 Exportar" onAction="#exportarHistorial" styleClass="actionBlue"/>
                    <Button text="🖨 Imprimir" onAction="#imprimirHistorial" styleClass="actionOrange"/>
                    <Button text="↻ Actualizar" onAction="#actualizarHistorial" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardGreen" prefWidth="230" prefHeight="95">
                        <Label text="Reparaciones"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Finalizadas"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardBlue" prefWidth="230" prefHeight="95">
