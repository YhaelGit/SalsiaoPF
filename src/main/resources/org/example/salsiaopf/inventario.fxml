<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.InventarioController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage" fitWidth="82" fitHeight="82" preserveRatio="true"/>
            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Inventario" styleClass="brandSubtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>
            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>
                <Button fx:id="btnNotificaciones" text="🔔 0" onAction="#mostrarNotificaciones" styleClass="notificationModernButton"/>
                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="INVENTARIO" styleClass="sideTitle"/>
            <Button text="📊  Dashboard" onAction="#mostrarDashboard" styleClass="sideButtonActive"/>
            <Button text="📦  Productos" onAction="#mostrarProductos" styleClass="sideButton"/>
            <Button text="📥  Entradas" onAction="#mostrarEntradas" styleClass="sideButton"/>
            <Button text="📤  Salidas" onAction="#mostrarSalidas" styleClass="sideButton"/>
            <Button text="🔄  Movimientos" onAction="#mostrarMovimientos" styleClass="sideButton"/>
            <Button text="⚠  Alertas" onAction="#mostrarAlertas" styleClass="sideButton"/>
            <Button text="🏷  Categorías" onAction="#mostrarCategorias" styleClass="sideButton"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="userCard">
                <Label text="Inventario" styleClass="userCardName"/>
                <Label text="Control de existencias." wrapText="true" styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorInventario" styleClass="contentArea">

            <!-- ═══════════════ DASHBOARD ═══════════════ -->
            <ScrollPane fx:id="scrollDashboard" fitToWidth="true" fitToHeight="true" visible="true" managed="true" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Dashboard de inventario" styleClass="pageTitle"/>
                        <Label text="Resumen general del inventario del restaurante." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtBuscarProducto" promptText="🔍 Buscar producto, código o categoría..." prefWidth="350"/>
                    <Button text="Buscar" onAction="#buscarProductos" styleClass="actionBlue"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="200" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Productos registrados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalProductos" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="200" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Stock bajo" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblStockBajo" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="200" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Agotados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblAgotados" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardPurple" prefWidth="200" prefHeight="85" GridPane.columnIndex="3">
                        <Label text="Vencidos" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblVencidos" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="200" prefHeight="85" GridPane.columnIndex="4">
                        <Label text="Valor inventario" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblValorInventario" text="RD$ 0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Existencias" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="📥 + Entrada" onAction="#irAEntradas" styleClass="actionGreen"/>
                        <Button text="📤 - Salida" onAction="#irASalidas" styleClass="actionOrange"/>
                        <Button text="📄 Exportar" onAction="#exportarReporte" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaProductos" prefHeight="400" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="110"/>
                            <TableColumn text="Producto" prefWidth="200"/>
                            <TableColumn text="Categoría" prefWidth="130"/>
                            <TableColumn text="Cantidad" prefWidth="90"/>
                            <TableColumn text="Unidad" prefWidth="70"/>
                            <TableColumn text="Costo" prefWidth="100"/>
                            <TableColumn text="Stock mín." prefWidth="90"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Vencimiento" prefWidth="120"/>
                            <TableColumn text="Acciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ PRODUCTOS ═══════════════ -->
            <ScrollPane fx:id="scrollProductos" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Productos" styleClass="pageTitle"/>
                        <Label text="Registra y administra los productos del inventario." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar" onAction="#guardarProducto" styleClass="actionGreen"/>
                    <Button text="↻ Nuevo" onAction="#nuevoProducto" styleClass="actionBlue"/>
                    <Button text="↻ Limpiar" onAction="#limpiarProducto" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Registro de producto" styleClass="cardTitle"/>
                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="110" prefWidth="110"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                            <ColumnConstraints minWidth="110" prefWidth="110"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtProdCodigo" editable="false" promptText="Generado automáticamente" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Categoría:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbProdCategoria" promptText="Seleccione categoría" editable="true" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtProdNombre" promptText="Nombre del producto" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Unidad:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbProdUnidad" promptText="Seleccione unidad (LB, KG, UN, L)" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Cantidad inicial:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtProdCantidad" promptText="Cantidad inicial (ej: 10)" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Costo x unidad:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtProdCosto" promptText="Costo por unidad (RD$)" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        <Label text="Stock mínimo:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtProdStockMin" promptText="Stock mínimo para alerta" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Estado:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbProdEstado" promptText="Estado inicial del producto" prefWidth="220" GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                        <Label text="Fecha vencimiento:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dateProdVenc" promptText="dd/mm/aaaa" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="Observación:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtProdObservacion" promptText="Notas del producto..." prefRowCount="2" wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de productos" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🗑 Eliminar" onAction="#eliminarProducto" styleClass="actionRed"/>
                        <Button text="↻ Actualizar" onAction="#actualizarProductos" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaProductosCRUD" prefHeight="300" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="100"/>
                            <TableColumn text="Nombre" prefWidth="180"/>
                            <TableColumn text="Categoría" prefWidth="120"/>
                            <TableColumn text="Cantidad" prefWidth="80"/>
                            <TableColumn text="Unidad" prefWidth="60"/>
                            <TableColumn text="Costo" prefWidth="90"/>
                            <TableColumn text="Estado" prefWidth="90"/>
                            <TableColumn text="Vencimiento" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ ENTRADAS ═══════════════ -->
            <ScrollPane fx:id="scrollEntradas" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Entradas de inventario" styleClass="pageTitle"/>
                        <Label text="Registra la llegada de nuevos productos al almacén." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Registrar entrada" onAction="#registrarEntrada" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarEntrada" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Registrar entrada de producto" styleClass="cardTitle"/>
                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="260" prefWidth="260"/>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="260" prefWidth="260"/>
                        </columnConstraints>

                        <Label text="Producto:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbEntradaProducto" promptText="Buscar producto..." prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Cantidad:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtEntradaCantidad" promptText="Cantidad a agregar" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dateEntrada" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Observación:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtEntradaObservacion" promptText="Motivo de entrada" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Info:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblEntradaInfo" text="Seleccione un producto para ver su información" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <Label text="Últimas entradas" styleClass="cardTitle"/>
                    <TableView fx:id="tablaEntradas" prefHeight="350" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Fecha" prefWidth="120"/>
                            <TableColumn text="Producto" prefWidth="220"/>
                            <TableColumn text="Cantidad" prefWidth="100"/>
                            <TableColumn text="Observación" prefWidth="250"/>
                            <TableColumn text="Usuario" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ SALIDAS ═══════════════ -->
            <ScrollPane fx:id="scrollSalidas" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Salidas de inventario" styleClass="pageTitle"/>
                        <Label text="Registra la salida de productos usados en cocina." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Registrar salida" onAction="#registrarSalida" styleClass="actionOrange"/>
                    <Button text="↻ Limpiar" onAction="#limpiarSalida" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Registrar salida de producto" styleClass="cardTitle"/>
                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="260" prefWidth="260"/>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="260" prefWidth="260"/>
                        </columnConstraints>

                        <Label text="Producto:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbSalidaProducto" promptText="Buscar producto..." prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Cantidad:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtSalidaCantidad" promptText="Cantidad a descontar" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Fecha:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dateSalida" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Observación:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtSalidaObservacion" promptText="Motivo de salida (ej: uso cocina)" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Info:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSalidaInfo" text="Seleccione un producto para ver su stock actual" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <Label text="Últimas salidas" styleClass="cardTitle"/>
                    <TableView fx:id="tablaSalidas" prefHeight="350" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Fecha" prefWidth="120"/>
                            <TableColumn text="Producto" prefWidth="220"/>
                            <TableColumn text="Cantidad" prefWidth="100"/>
                            <TableColumn text="Observación" prefWidth="250"/>
                            <TableColumn text="Usuario" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ MOVIMIENTOS ═══════════════ -->
            <ScrollPane fx:id="scrollMovimientos" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Movimientos de inventario" styleClass="pageTitle"/>
                        <Label text="Historial completo de entradas y salidas del almacén." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="txtBuscarMovimiento" promptText="🔍 Buscar en movimientos..." prefWidth="350"/>
                    <Button text="Buscar" onAction="#buscarMovimientos" styleClass="actionBlue"/>
                    <Button text="↻ Actualizar" onAction="#actualizarMovimientos" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <TableView fx:id="tablaMovimientos" prefHeight="600" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Tipo" prefWidth="100"/>
                            <TableColumn text="Código" prefWidth="110"/>
                            <TableColumn text="Producto" prefWidth="220"/>
                            <TableColumn text="Cantidad" prefWidth="100"/>
                            <TableColumn text="Fecha" prefWidth="120"/>
                            <TableColumn text="Observación" prefWidth="250"/>
                            <TableColumn text="Usuario" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ ALERTAS ═══════════════ -->
            <ScrollPane fx:id="scrollAlertas" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Alertas de inventario" styleClass="pageTitle"/>
                        <Label text="Productos con stock bajo y productos vencidos." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="↻ Actualizar" onAction="#actualizarAlertas" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="300" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Stock bajo"/>
                        <Label fx:id="lblAlertStockBajo" text="0" styleClass="metricValueSmall"/>
                        <Label text="Productos por debajo del mínimo"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="300" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Vencidos"/>
                        <Label fx:id="lblAlertVencidos" text="0" styleClass="metricValueSmall"/>
                        <Label text="Productos con fecha vencida"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardPurple" prefWidth="300" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Valor en riesgo"/>
                        <Label fx:id="lblAlertValorRiesgo" text="RD$ 0" styleClass="metricValueSmall"/>
                        <Label text="Productos vencidos o próximos a vencer"/>
                    </VBox>
                </GridPane>

                <VBox styleClass="cardPanel" spacing="12">
                    <Label text="⚠ Productos con stock bajo" styleClass="cardTitle" style="-fx-text-fill: #e67e22;"/>
                    <TableView fx:id="tablaStockBajo" prefHeight="250" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="110"/>
                            <TableColumn text="Producto" prefWidth="250"/>
                            <TableColumn text="Unidad" prefWidth="70"/>
                            <TableColumn text="Stock actual" prefWidth="120"/>
                            <TableColumn text="Stock mínimo" prefWidth="120"/>
                            <TableColumn text="Faltante" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <Label text="🚫 Productos vencidos" styleClass="cardTitle" style="-fx-text-fill: #e74c3c;"/>
                    <TableView fx:id="tablaVencidos" prefHeight="250" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="110"/>
                            <TableColumn text="Producto" prefWidth="250"/>
                            <TableColumn text="Categoría" prefWidth="150"/>
                            <TableColumn text="Cantidad" prefWidth="100"/>
                            <TableColumn text="Vence" prefWidth="130"/>
                            <TableColumn text="Días vencido" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ CATEGORÍAS ═══════════════ -->
            <ScrollPane fx:id="scrollCategorias" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Categorías" styleClass="pageTitle"/>
                        <Label text="Administra las categorías de productos del inventario." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar" onAction="#guardarCategoria" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarCategoria" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Registro de categoría" styleClass="cardTitle"/>
                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="300" prefWidth="300"/>
                        </columnConstraints>
                        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtCatNombre" promptText="Nombre de la categoría" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        <Label text="Descripción:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtCatDescripcion" promptText="Descripción opcional" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de categorías" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🗑 Eliminar" onAction="#eliminarCategoria" styleClass="actionRed"/>
                        <Button text="↻ Actualizar" onAction="#actualizarCategorias" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaCategorias" prefHeight="350" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Nombre" prefWidth="200"/>
                            <TableColumn text="Descripción" prefWidth="300"/>
                            <TableColumn text="Productos" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
