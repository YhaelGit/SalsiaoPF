<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox styleClass="appRoot" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.salsiaopf.controller.VentaController">
  <HBox VBox.vgrow="ALWAYS">
    <!-- Sidebar -->
    <VBox styleClass="sideBar" spacing="8" minWidth="240" maxWidth="240">
      <VBox spacing="6">
        <Text text="SALSIAO" styleClass="brandTitle"/>
        <Text text="Modulo Ventas" styleClass="brandSubtitle"/>
      </VBox>
      <Separator style="-fx-background: rgba(255,255,255,0.1); -fx-padding: 8 0;"/>
      <VBox spacing="6">
        <Button fx:id="btnDashboard" text="📊  Dashboard" styleClass="sideButtonActive" onAction="#mostrarDashboard"/>
        <Button fx:id="btnNuevaVenta" text="🛒  Nueva Venta" styleClass="sideButton" onAction="#mostrarVenta"/>
        <Button fx:id="btnHistorial" text="📋  Historial" styleClass="sideButton" onAction="#mostrarHistorial"/>
        <Button fx:id="btnCaja" text="💰  Caja / Cierre" styleClass="sideButton" onAction="#mostrarCaja"/>
        <Button fx:id="btnPedidos" text="📦  Pedidos" styleClass="sideButton" onAction="#mostrarPedidos"/>
      </VBox>
      <Region VBox.vgrow="ALWAYS"/>
      <Button fx:id="btnLimpiar" text="🧹  Limpiar" styleClass="sideButton" onAction="#limpiar"/>
      <Separator style="-fx-background: rgba(255,255,255,0.1);"/>
      <Button text="🔙  Volver al Sistema" styleClass="sideButtonExit" onAction="#volverMenu" maxWidth="Infinity"/>
    </VBox>

    <!-- Content -->
    <StackPane fx:id="contentPanel" HBox.hgrow="ALWAYS" styleClass="contentArea">

      <!-- DASHBOARD -->
      <ScrollPane fx:id="scrollDashboard" styleClass="contentScroll" fitToWidth="true" visible="false" managed="false">
        <VBox spacing="20" styleClass="content">
          <VBox spacing="6">
            <Text text="Panel de Ventas" styleClass="pageTitle"/>
            <Text text="Resumen del dia y actividad reciente" styleClass="pageSubtitle"/>
          </VBox>
          <HBox spacing="16">
            <VBox fx:id="cardVentasHoy" styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="6">
              <Text text="💰 Ventas Hoy" styleClass="cardTitle"/>
              <Label fx:id="lblVentasHoy" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1f2937;" text="RD$ 0"/>
              <Label fx:id="lblCantVentasHoy" style="-fx-text-fill:#6b7280;" text="0 transacciones"/>
            </VBox>
            <VBox fx:id="cardProductos" styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="6">
              <Text text="🍔 Productos" styleClass="cardTitle"/>
              <Label fx:id="lblTotalProductos" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1f2937;" text="0"/>
              <Text text="En el catalogo" style="-fx-text-fill:#6b7280;"/>
            </VBox>
            <VBox fx:id="cardTipoVenta" styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="6">
              <Text text="📊 Venta Mas Usada" styleClass="cardTitle"/>
              <Label fx:id="lblTipoVentaFrecuente" style="-fx-font-size:28px; -fx-font-weight:bold; -fx-text-fill:#1f2937;" text="Mostrador"/>
            </VBox>
          </HBox>
          <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
            <Text text="Ventas Recientes" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
            <TableView fx:id="tablaVentasRecientes" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colFactura" text="Factura" prefWidth="150"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="170"/>
                <TableColumn fx:id="colCliente" text="Cliente" prefWidth="160"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="110"/>
                <TableColumn fx:id="colMetodo" text="Pago" prefWidth="110"/>
                <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
              </columns>
            </TableView>
          </VBox>
        </VBox>
      </ScrollPane>

      <!-- POS / NUEVA VENTA -->
      <ScrollPane fx:id="scrollVenta" styleClass="contentScroll" fitToWidth="true" fitToHeight="true" visible="true" managed="true">
        <HBox spacing="16" styleClass="content" HBox.hgrow="ALWAYS">
          <VBox spacing="12" HBox.hgrow="ALWAYS" minWidth="450">
            <Text text="🛒 Nuevo Pedido" style="-fx-font-size:22px; -fx-font-weight:bold;"/>
            <TextField fx:id="txtBuscar" promptText="🔍 Buscar producto..." styleClass="posSearchBox"/>
            <FlowPane fx:id="panelCategorias" styleClass="posCategoryPanel"/>
            <ScrollPane styleClass="posProductScroll" fitToWidth="true" VBox.vgrow="ALWAYS">
              <FlowPane fx:id="panelProductos" styleClass="posProductGrid" hgap="14" vgap="14" />
            </ScrollPane>
          </VBox>
          <VBox spacing="12" minWidth="340" maxWidth="380" styleClass="posCartPanel">
            <HBox spacing="8" alignment="CENTER_LEFT">
              <Text text="🧾 Pedido" styleClass="posCartTitle"/>
              <Region HBox.hgrow="ALWAYS"/>
              <Label fx:id="lblCartCount" text="0" styleClass="posCartCount"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
              <Text text="Tipo:" style="-fx-font-weight:bold;"/>
              <ComboBox fx:id="cmbTipoVenta" style="-fx-background-radius:6;"/>
              <Text text="Cliente:" style="-fx-font-weight:bold;"/>
              <ComboBox fx:id="cmbCliente" style="-fx-background-radius:6;" maxWidth="180" promptText="Seleccionar..."/>
              <Region HBox.hgrow="ALWAYS"/>
            </HBox>
            <Separator/>
            <ScrollPane styleClass="contentScroll" fitToWidth="true" VBox.vgrow="ALWAYS">
              <ListView fx:id="listCart" style="-fx-background-color:transparent; -fx-border-color:transparent;"/>
            </ScrollPane>
            <Separator/>
            <GridPane hgap="10" vgap="6" minWidth="0">
              <columnConstraints>
                <ColumnConstraints minWidth="120" halignment="LEFT"/>
                <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
              </columnConstraints>
              <Text text="Subtotal:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
              <Label fx:id="lblSubtotal" text="RD$ 0.00" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
              <Text text="ITBIS (18%):" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill:#6b7280;"/>
              <Label fx:id="lblITBIS" text="RD$ 0.00" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill:#6b7280;"/>
              <Text text="Descuento:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill:#6b7280;"/>
              <HBox spacing="4" GridPane.rowIndex="2" GridPane.columnIndex="1" alignment="CENTER_RIGHT">
                <Text text="RD$" style="-fx-text-fill:#6b7280;"/>
                <TextField fx:id="txtDescuento" text="0" prefWidth="80" style="-fx-alignment:center-right;"/>
              </HBox>
              <Text text="Delivery:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-text-fill:#6b7280;"/>
              <HBox spacing="4" GridPane.rowIndex="3" GridPane.columnIndex="1" alignment="CENTER_RIGHT">
                <Text text="RD$" style="-fx-text-fill:#6b7280;"/>
                <TextField fx:id="txtDelivery" text="0" prefWidth="80" style="-fx-alignment:center-right;"/>
              </HBox>
              <Separator GridPane.rowIndex="4" GridPane.columnSpan="2"/>
              <Text text="TOTAL:" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1f2937;"/>
              <Label fx:id="lblTotal" text="RD$ 0.00" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-font-size:22px; -fx-font-weight:900; -fx-text-fill:#059669;"/>
            </GridPane>
            <Button fx:id="btnCheckout" text="✅  Procesar Pago" styleClass="posCheckoutBtn" maxWidth="Infinity" onAction="#procesarPago"/>
          </VBox>
        </HBox>
      </ScrollPane>

      <!-- HISTORIAL -->
      <ScrollPane fx:id="scrollHistorial" styleClass="contentScroll" fitToWidth="true" visible="false" managed="false">
        <VBox spacing="20" styleClass="content">
          <VBox spacing="6">
            <Text text="📋 Historial de Ventas" styleClass="pageTitle"/>
            <Text text="Todas las transacciones registradas" styleClass="pageSubtitle"/>
          </VBox>
          <HBox spacing="12">
            <DatePicker fx:id="dpDesde" promptText="Desde" style="-fx-background-radius:6;"/>
            <DatePicker fx:id="dpHasta" promptText="Hasta" style="-fx-background-radius:6;"/>
            <Button text="🔍 Filtrar" styleClass="topButton" onAction="#filtrarHistorial"/>
            <Button text="🔄 Limpiar Filtros" styleClass="topButton" onAction="#limpiarFiltrosHistorial"/>
          </HBox>
          <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
            <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colHFactura" text="Factura" prefWidth="150"/>
                <TableColumn fx:id="colHFecha" text="Fecha" prefWidth="170"/>
                <TableColumn fx:id="colHCliente" text="Cliente" prefWidth="160"/>
                <TableColumn fx:id="colHTipo" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colHMetodo" text="Pago" prefWidth="110"/>
                <TableColumn fx:id="colHTotal" text="Total" prefWidth="120"/>
              </columns>
            </TableView>
          </VBox>
        </VBox>
      </ScrollPane>

      <!-- CAJA / CIERRE DE CAJA -->
      <ScrollPane fx:id="scrollCaja" styleClass="contentScroll" fitToWidth="true" visible="false" managed="false">
        <VBox spacing="20" styleClass="content">
          <VBox spacing="6">
            <Text text="💰 Caja / Cierre de Caja" styleClass="pageTitle"/>
            <Text text="Control de ingresos del dia" styleClass="pageSubtitle"/>
          </VBox>

          <!-- Estado caja indicator -->
          <HBox spacing="16">
            <VBox styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="8">
              <Text text="Estado de Caja" styleClass="cardTitle"/>
              <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="lblEstadoCaja" text="🔴 Cerrada" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
                <Label fx:id="lblCajaUsuario" text="" style="-fx-text-fill:#6b7280;"/>
              </HBox>
            </VBox>
            <VBox styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="8">
              <Text text="Apertura" styleClass="cardTitle"/>
              <Label fx:id="lblCajaApertura" text="--:--" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            </VBox>
            <VBox styleClass="cardPanel" HBox.hgrow="ALWAYS" spacing="8">
              <Text text="Monto Inicial" styleClass="cardTitle"/>
              <Label fx:id="lblCajaMontoInicial" text="RD$ 0.00" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            </VBox>
          </HBox>

          <!-- Totales -->
          <HBox spacing="16">
            <VBox styleClass="cajaCardEfectivo" HBox.hgrow="ALWAYS" spacing="2" alignment="CENTER_LEFT" prefWidth="0">
              <Text text="💵 Efectivo" style="-fx-font-size:13px; -fx-fill:#fff; -fx-font-weight:bold;"/>
              <Separator style="-fx-background:rgba(255,255,255,0.2); -fx-pref-height:1;"/>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Declarado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaEfectivo" text="RD$ 0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#fff;"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Esperado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaEfectivoEsp" text="RD$ 0" style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.8);"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Diff:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaEfectivoDiff" text="RD$ 0" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
              </HBox>
            </VBox>
            <VBox styleClass="cajaCardTarjeta" HBox.hgrow="ALWAYS" spacing="2" alignment="CENTER_LEFT" prefWidth="0">
              <Text text="💳 Tarjeta" style="-fx-font-size:13px; -fx-fill:#fff; -fx-font-weight:bold;"/>
              <Separator style="-fx-background:rgba(255,255,255,0.2); -fx-pref-height:1;"/>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Declarado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTarjeta" text="RD$ 0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#fff;"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Esperado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTarjetaEsp" text="RD$ 0" style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.8);"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Diff:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTarjetaDiff" text="RD$ 0" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
              </HBox>
            </VBox>
            <VBox styleClass="cajaCardTransferencia" HBox.hgrow="ALWAYS" spacing="2" alignment="CENTER_LEFT" prefWidth="0">
              <Text text="🏦 Transferencia" style="-fx-font-size:13px; -fx-fill:#fff; -fx-font-weight:bold;"/>
              <Separator style="-fx-background:rgba(255,255,255,0.2); -fx-pref-height:1;"/>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Declarado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTransferencia" text="RD$ 0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#fff;"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Esperado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTransferenciaEsp" text="RD$ 0" style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.8);"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Diff:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTransferenciaDiff" text="RD$ 0" style="-fx-font-size:12px; -fx-font-weight:bold;"/>
              </HBox>
            </VBox>
            <VBox styleClass="cajaCardTotal" HBox.hgrow="ALWAYS" spacing="2" alignment="CENTER_LEFT" prefWidth="0">
              <Text text="📊 Totales" style="-fx-font-size:13px; -fx-fill:#fff; -fx-font-weight:bold;"/>
              <Separator style="-fx-background:rgba(255,255,255,0.2); -fx-pref-height:1;"/>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Declarado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTotalGeneral" text="RD$ 0" style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#fff;"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Esperado:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaTotalGeneralEsp" text="RD$ 0" style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.8);"/>
              </HBox>
              <HBox spacing="4" alignment="CENTER_LEFT">
                <Text text="Diff:" style="-fx-font-size:10px; -fx-fill:rgba(255,255,255,0.6);"/>
                <Label fx:id="lblCajaDiferencia" text="RD$ 0" style="-fx-font-size:14px; -fx-font-weight:bold;"/>
              </HBox>
            </VBox>
          </HBox>

          <!-- Form / Actions -->
          <VBox styleClass="cardPanel" spacing="12">
            <Text text="Opciones de Caja" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            <GridPane hgap="12" vgap="8">
              <columnConstraints>
                <ColumnConstraints minWidth="140" halignment="LEFT"/>
                <ColumnConstraints hgrow="ALWAYS" halignment="LEFT"/>
              </columnConstraints>
              <Text text="Monto Inicial:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
              <TextField fx:id="txtCajaMontoInicial" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" promptText="RD$ 0.00"/>
              <Text text="Total Efectivo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
              <TextField fx:id="txtCajaEfectivo" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200" promptText="RD$ 0.00"/>
              <Text text="Total Tarjeta:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
              <TextField fx:id="txtCajaTarjeta" text="0" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200" promptText="RD$ 0.00"/>
              <Text text="Total Transferencia:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
              <TextField fx:id="txtCajaTransferencia" text="0" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200" promptText="RD$ 0.00"/>
              <Text text="Diferencia:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight:bold; -fx-text-fill:#059669;"/>
              <Label fx:id="lblCajaDiffForm" text="RD$ 0.00" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            </GridPane>
            <HBox spacing="12">
              <Button fx:id="btnAbrirCaja" text="🔓 Abrir Caja" styleClass="cajaBtnAbrir" onAction="#abrirCaja"/>
              <Button fx:id="btnCerrarCaja" text="🔒 Cerrar Caja" styleClass="cajaBtnCerrar" onAction="#cerrarCaja"/>
              <Button text="📄 Ver Resumen" styleClass="topButton" onAction="#verResumenCaja"/>
              <Button text="📤 Exportar" styleClass="topButton" onAction="#exportarCaja"/>
              <Button text="🔄 Limpiar" styleClass="topButton" onAction="#limpiarCamposCaja"/>
            </HBox>
          </VBox>

          <!-- Historial de cierres -->
          <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
            <Text text="Historial de Cierres" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            <TableView fx:id="tablaCierres" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colCFechaApertura" text="Apertura" prefWidth="160"/>
                <TableColumn fx:id="colCFechaCierre" text="Cierre" prefWidth="160"/>
                <TableColumn fx:id="colCUsuario" text="Usuario" prefWidth="120"/>
                <TableColumn fx:id="colCInicial" text="Inicial" prefWidth="100"/>
                <TableColumn fx:id="colCEfectivo" text="Efectivo" prefWidth="100"/>
                <TableColumn fx:id="colCTarjeta" text="Tarjeta" prefWidth="100"/>
                <TableColumn fx:id="colCTransferencia" text="Transf." prefWidth="100"/>
                <TableColumn fx:id="colCTotal" text="Total" prefWidth="110"/>
                <TableColumn fx:id="colCDiferencia" text="Diff." prefWidth="100"/>
              </columns>
            </TableView>
          </VBox>
        </VBox>
      </ScrollPane>

      <!-- PEDIDOS PENDIENTES -->
      <ScrollPane fx:id="scrollPedidos" styleClass="contentScroll" fitToWidth="true" visible="false" managed="false">
        <VBox spacing="20" styleClass="content">
          <VBox spacing="6">
            <Text text="📦 Pedidos Pendientes" styleClass="pageTitle"/>
            <Text text="Control de pedidos activos" styleClass="pageSubtitle"/>
          </VBox>

          <!-- Filtros -->
          <HBox spacing="12" alignment="CENTER_LEFT">
            <ComboBox fx:id="cmbFiltroCliente" prefWidth="240" promptText="Seleccionar cliente..." style="-fx-background-radius:6;"/>
            <ComboBox fx:id="cmbFiltroEstado" prefWidth="160" promptText="Filtrar por estado..." style="-fx-background-radius:6;"/>
            <TextField fx:id="txtBuscarPedido" promptText="🔍 Buscar factura o items..." prefWidth="200" styleClass="posSearchBox"/>
            <Button text="🔍 Filtrar" styleClass="topButton" onAction="#filtrarPedidos"/>
            <Button text="🔄 Limpiar" styleClass="topButton" onAction="#limpiarFiltrosPedidos"/>
          </HBox>

          <!-- Tabla de pedidos -->
          <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
            <TableView fx:id="tablaPedidos" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colPId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colPFactura" text="Factura" prefWidth="150"/>
                <TableColumn fx:id="colPCliente" text="Cliente" prefWidth="160"/>
                <TableColumn fx:id="colPItems" text="Items" prefWidth="200"/>
                <TableColumn fx:id="colPTotal" text="Total" prefWidth="110"/>
                <TableColumn fx:id="colPEstado" text="Estado" prefWidth="120"/>
                <TableColumn fx:id="colPFecha" text="Fecha" prefWidth="150"/>
                <TableColumn fx:id="colPTipo" text="Tipo" prefWidth="100"/>
              </columns>
            </TableView>
          </VBox>

          <!-- Panel de detalle y acciones -->
          <VBox fx:id="panelDetallePedido" visible="false" managed="false" styleClass="pedidoDetallePanel" spacing="12">
            <Text text="Detalle del Pedido" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            <HBox spacing="20">
              <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblDetalleFactura" text="Factura: --" style="-fx-font-weight:bold;"/>
                <Label fx:id="lblDetalleCliente" text="Cliente: --"/>
                <Label fx:id="lblDetalleItems" text="Items: --" wrapText="true"/>
                <Label fx:id="lblDetalleFecha" text="Fecha: --"/>
              </VBox>
              <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblDetalleTotal" text="Total: RD$ 0.00" style="-fx-font-weight:bold; -fx-font-size:16px;"/>
                <Label fx:id="lblDetalleTipo" text="Tipo: --"/>
                <Label fx:id="lblDetallePago" text="Pago: --"/>
                <Label fx:id="lblDetalleObservaciones" text="Obs: --" wrapText="true"/>
              </VBox>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
              <Text text="Cliente:" style="-fx-font-weight:bold;"/>
              <ComboBox fx:id="cmbPedidoCliente" prefWidth="250" promptText="Asignar cliente..."/>
              <Button text="✅ Asignar" styleClass="topButton" onAction="#asignarClientePedido"/>
            </HBox>
            <Separator/>
            <HBox spacing="12">
              <Button fx:id="btnCambiarEstado" text="🔄 Cambiar Estado" styleClass="pedidoBtnEstado" onAction="#cambiarEstadoPedido"/>
              <Button fx:id="btnCobrarPedido" text="💰 Cobrar" styleClass="posCheckoutBtn" onAction="#cobrarPedido"/>
              <Button fx:id="btnCancelarPedido" text="❌ Cancelar" styleClass="pedidoBtnCancelar" onAction="#cancelarPedido"/>
            </HBox>
          </VBox>
        </VBox>
      </ScrollPane>

      <!-- PAYMENT OVERLAY -->
      <StackPane fx:id="pagoOverlay" visible="false" managed="false" styleClass="posOverlay">
        <VBox spacing="16" styleClass="posOverlayCard">
          <Text text="💳 Procesar Pago" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1f2937;"/>
          <Separator/>

          <VBox fx:id="panelClienteInfo" spacing="4" visible="false" managed="false" style="-fx-background-color:#f0f4ff; -fx-background-radius:10; -fx-padding:12;">
            <Label fx:id="lblPagoClienteNombre" style="-fx-font-weight:bold; -fx-font-size:14px; -fx-text-fill:#1a1a2e;"/>
            <Label fx:id="lblPagoClienteTelefono" style="-fx-font-size:12px; -fx-text-fill:#495057;"/>
            <Label fx:id="lblPagoClienteEmail" style="-fx-font-size:12px; -fx-text-fill:#495057;"/>
            <Label fx:id="lblPagoClienteDireccion" style="-fx-font-size:12px; -fx-text-fill:#495057;"/>
          </VBox>

          <GridPane hgap="10" vgap="8" minWidth="0">
            <columnConstraints>
              <ColumnConstraints minWidth="120" halignment="LEFT"/>
              <ColumnConstraints hgrow="ALWAYS" halignment="RIGHT"/>
            </columnConstraints>
            <Text text="Total a Pagar:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
            <Label fx:id="lblPagoTotal" text="RD$ 0.00" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#059669;"/>
            <Text text="Cliente:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbPagoCliente" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity" promptText="Seleccionar cliente..."/>
            <Text text="Metodo de Pago:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbMetodoPago" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Text text="Monto Recibido:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtMontoRecibido" text="0" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="RD$ 0.00" style="-fx-alignment:center-right;"/>
            <Text text="Devuelta:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <Label fx:id="lblDevuelta" text="RD$ 0.00" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill:#059669; -fx-font-weight:bold;"/>
            <Text text="Email Cliente:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEmailCliente" GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="cliente@ejemplo.com"/>
            <Text text="Observaciones:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="txtObservaciones" GridPane.rowIndex="6" GridPane.columnIndex="1" promptText="Opcional"/>
          </GridPane>
          <HBox spacing="12" alignment="CENTER">
            <Button text="❌ Cancelar" styleClass="topButton" onAction="#cancelarPago"/>
            <Button fx:id="btnConfirmarPago" text="✅  Confirmar Pago" styleClass="posConfirmBtn" onAction="#confirmarPago"/>
          </HBox>
        </VBox>
      </StackPane>
    </StackPane>
  </HBox>
</VBox>
