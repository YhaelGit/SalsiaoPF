<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.VentaController"
            styleClass="appRoot">

    <fx:define>
        <ToggleGroup fx:id="grupoPago"/>
    </fx:define>

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Ventas" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>

            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 0"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="VENTAS" styleClass="sideTitle"/>

            <Button fx:id="btnControlVenta" text="🍔  Menú digital" onAction="#mostrarControlVenta" styleClass="sideButtonActive"/>
            <Button fx:id="btnOrdenActual" text="🧺  Orden actual" onAction="#mostrarOrdenActual" styleClass="sideButton"/>
            <Button fx:id="btnPago" text="💳  Pago" onAction="#mostrarPago" styleClass="sideButton"/>
            <Button fx:id="btnFacturacion" text="🧾  Facturación electrónica" onAction="#mostrarFacturacion" styleClass="sideButton"/>
            <Button fx:id="btnPedidosPendientes" text="⏱  Pedidos pendientes" onAction="#mostrarPedidosPendientes" styleClass="sideButton"/>
            <Button fx:id="btnDelivery" text="🏍  Delivery" onAction="#mostrarDelivery" styleClass="sideButton"/>
            <Button fx:id="btnMesas" text="🍽  Mesas y consumos" onAction="#mostrarMesas" styleClass="sideButton"/>
            <Button fx:id="btnProductos" text="🍽  Productos" onAction="#mostrarProductos" styleClass="sideButton"/>
            <Button fx:id="btnCaja" text="💰  Control de caja" onAction="#mostrarCaja" styleClass="sideButton"/>
            <Button fx:id="btnHistorialVentas" text="↺  Historial de ventas" onAction="#mostrarHistorialVentas" styleClass="sideButton"/>
            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="userCard">
                <Label text="Venta"
                       styleClass="userCardName"/>

                <Label text="Gestión de la venta."
                       wrapText="true"
                       styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorVentas" styleClass="contentArea">

            <VBox fx:id="viewProductos" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Productos" styleClass="pageTitle"/>
                        <Label text="Administra los productos vendidos, precios, categorías, recetas y disponibilidad." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo producto" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" styleClass="actionRed"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del producto" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Producto:" minWidth="130" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtIdProducto" editable="false" promptText="Automático" prefWidth="260"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Categoría:" minWidth="130" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbCategoriaProducto" promptText="Categoría" prefWidth="250"
                                      GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Nombre:" minWidth="130" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombreProducto" promptText="Nombre del producto" prefWidth="260"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Precio venta:" minWidth="130" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtPrecioProducto" promptText="0.00" prefWidth="250"
                                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Costo estimado:" minWidth="130" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtCostoProducto" editable="false" promptText="Calculado por receta" prefWidth="260"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Tiempo prep.:" minWidth="130" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtTiempoPreparacion" promptText="Minutos" prefWidth="250"
                                       GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Estado:" minWidth="130" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbEstadoProducto" promptText="Disponible" prefWidth="260"
                                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Tipo:" minWidth="130" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbTipoProducto" promptText="Plato / Bebida / Combo" prefWidth="250"
                                      GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Descripción:" minWidth="130" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextArea fx:id="txtDescripcionProducto" promptText="Descripción del producto..."
                                      prefRowCount="3" prefWidth="260"
                                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Imagen:" minWidth="130" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                            <HBox spacing="8" GridPane.rowIndex="4" GridPane.columnIndex="3">
                                <TextField fx:id="txtImagenProducto" promptText="Ruta de imagen" prefWidth="180"/>
                                <Button text="📁" styleClass="actionNeutral"/>
                            </HBox>
                        </GridPane>
                    </VBox>

                    <VBox spacing="16" prefWidth="390">
                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Resumen" styleClass="cardTitle"/>

                            <HBox>
                                <Label text="Productos activos:"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="0"/>
                            </HBox>

                            <HBox>
                                <Label text="No disponibles:"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="0"/>
                            </HBox>

                            <HBox>
                                <Label text="Costo promedio:"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="RD$ 0.00"/>
                            </HBox>

                            <HBox>
                                <Label text="Margen estimado:"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="0%"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Acciones rápidas" styleClass="cardTitle"/>

                            <Button text="+ Agregar ingrediente a receta" styleClass="actionBlue" prefHeight="42"/>
                            <Button text="📦 Ver ingredientes usados" styleClass="actionNeutral" prefHeight="42"/>
                            <Button text="✔ Marcar disponible" styleClass="actionGreen" prefHeight="42"/>
                            <Button text="✖ Marcar no disponible" styleClass="actionRed" prefHeight="42"/>
                        </VBox>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Receta del producto" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox promptText="Ingrediente" prefWidth="240"/>
                        <TextField promptText="Cantidad" prefWidth="120"/>
                        <ComboBox promptText="Unidad" prefWidth="120"/>
                        <Button text="+ Agregar" styleClass="actionBlue"/>
                    </HBox>

                    <TableView fx:id="tablaRecetaProducto" prefHeight="170">
                        <columns>
                            <TableColumn text="ID" prefWidth="80"/>
                            <TableColumn text="Ingrediente" prefWidth="280"/>
                            <TableColumn text="Cantidad" prefWidth="130"/>
                            <TableColumn text="Unidad" prefWidth="120"/>
                            <TableColumn text="Costo unidad" prefWidth="150"/>
                            <TableColumn text="Costo total" prefWidth="150"/>
                            <TableColumn text="Acciones" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de productos" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox promptText="Categoría" prefWidth="180"/>
                        <ComboBox promptText="Estado" prefWidth="160"/>
                        <TextField promptText="Buscar producto..." prefWidth="240"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaProductos" prefHeight="300">
                        <columns>
                            <TableColumn text="ID Producto" prefWidth="130"/>
                            <TableColumn text="Nombre" prefWidth="260"/>
                            <TableColumn text="Categoría" prefWidth="180"/>
                            <TableColumn text="Tipo" prefWidth="130"/>
                            <TableColumn text="Precio" prefWidth="130"/>
                            <TableColumn text="Costo" prefWidth="130"/>
                            <TableColumn text="Margen" prefWidth="120"/>
                            <TableColumn text="Estado" prefWidth="140"/>
                            <TableColumn text="Tiempo prep." prefWidth="140"/>
                            <TableColumn text="Acciones" prefWidth="160"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

            <!-- MENÚ DIGITAL — Control de venta premium -->
            <VBox fx:id="viewControlVenta" styleClass="ventasMenuRoot" spacing="0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">

                <HBox spacing="0" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308">

                    <!-- Categorías -->
                    <VBox styleClass="ventasSideCategorias" prefWidth="210" minWidth="190">
                        <Label text="SALSIAO" styleClass="ventasBrandMini"/>
                        <Label text="MENÚ" styleClass="ventasSideTitle"/>
                        <ScrollPane fitToWidth="true" styleClass="ventasScrollCat" VBox.vgrow="ALWAYS">
                            <VBox fx:id="panelCategorias" spacing="6"/>
                        </ScrollPane>
                    </VBox>

                    <!-- Grid de productos -->
                    <VBox styleClass="ventasCentro" spacing="14" HBox.hgrow="ALWAYS">
                        <HBox styleClass="ventasHeaderBar" alignment="CENTER_LEFT" spacing="16">
                            <VBox spacing="4">
                                <Label fx:id="lblCategoriaActiva" text="Todos los productos" styleClass="ventasTituloSeccion"/>
                                <Label text="Menú digital · Venta rápida" styleClass="ventasSubtitulo"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="txtBuscarMenu" promptText="🔍  Buscar producto..." styleClass="ventasBuscar" prefWidth="280"/>
                        </HBox>
                        <ScrollPane fx:id="scrollMenuProductos" fitToWidth="true" styleClass="ventasScrollProductos" VBox.vgrow="ALWAYS">
                            <FlowPane fx:id="gridProductos" hgap="18" vgap="18" styleClass="ventasFlowGrid"/>
                        </ScrollPane>
                    </VBox>

                    <!-- Carrito lateral -->
                    <VBox styleClass="ventasCarritoPanel" prefWidth="400" minWidth="340">
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="ventasCarritoHeader">
                            <Label text="🛒" styleClass="ventasCarritoIcon"/>
                            <VBox spacing="2">
                                <Label text="Orden actual" styleClass="ventasCarritoTitulo"/>
                                <Label fx:id="lblContadorItems" text="0 productos" styleClass="ventasCarritoSub"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTotalCarritoHeader" text="RD$ 0" styleClass="ventasTotalBadge"/>
                        </HBox>
                        <ScrollPane fx:id="scrollCarrito" fitToWidth="true" styleClass="ventasScrollCarrito" VBox.vgrow="ALWAYS">
                            <VBox fx:id="panelItemsCarrito" spacing="10"/>
                        </ScrollPane>
                        <VBox styleClass="ventasCarritoFooter" spacing="10">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Subtotal" styleClass="ventasResumenLabel"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblSubtotalCarrito" text="RD$ 0.00" styleClass="ventasResumenValor"/>
                            </HBox>
                            <Separator styleClass="ventasSeparador"/>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="TOTAL" styleClass="ventasTotalLabel"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblTotalCarrito" text="RD$ 0.00" styleClass="ventasTotalValor"/>
                            </HBox>
                            <Button text="💳  PROCESAR PAGO" onAction="#procesarPago" maxWidth="Infinity" styleClass="ventasBtnFinalizar"/>
                            <HBox spacing="8">
                                <Button text="↻ Vaciar" onAction="#vaciarCarrito" HBox.hgrow="ALWAYS" styleClass="ventasBtnSecundario"/>
                                <Button text="Ir a pago →" onAction="#irAPago" HBox.hgrow="ALWAYS" styleClass="ventasBtnIrPago"/>
                            </HBox>
                        </VBox>
                    </VBox>

                </HBox>

            </VBox>

            <VBox fx:id="viewOrdenActual" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Orden actual" styleClass="pageTitle"/>
                        <Label text="Administra y controla la orden activa antes del pago." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="↻ Actualizar" styleClass="actionNeutral"/>
                    <Button text="✎ Editar orden" styleClass="actionOrange"/>
                    <Button text="✖ Cancelar orden" styleClass="actionRed"/>
                    <Button text="✔ Enviar a cocina" styleClass="actionBlue"/>
                    <Button text="Continuar a pago" onAction="#procesarPago" styleClass="actionGreen"/>
                </HBox>

                <HBox spacing="16">

                    <!-- PANEL IZQUIERDO -->
                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">

                        <Label text="Información de la orden" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">

                            <columnConstraints>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                                <ColumnConstraints minWidth="120" prefWidth="120"/>
                                <ColumnConstraints minWidth="260" prefWidth="260"/>
                            </columnConstraints>

                            <Label text="Orden:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField text="ORD-00125"
                                       editable="false"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                            <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField promptText="Cliente seleccionado"
                                       editable="false"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="3"/>

                            <Label text="Mesa:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <ComboBox promptText="Mesa opcional"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="1"/>

                            <Label text="Tipo:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Salón / Delivery / Para llevar"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="3"/>

                            <Label text="Atiende:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField text="Admin"
                                       editable="false"
                                       GridPane.rowIndex="2"
                                       GridPane.columnIndex="1"/>

                        </GridPane>

                        <VBox spacing="10">

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Detalle de productos" styleClass="cardTitle"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <TableView prefHeight="360">

                                <columns>

                                    <TableColumn text="Producto" prefWidth="240"/>
                                    <TableColumn text="Cant." prefWidth="80"/>
                                    <TableColumn text="Precio" prefWidth="110"/>
                                    <TableColumn text="Subtotal" prefWidth="120"/>
                                    <TableColumn text="Estado" prefWidth="130"/>
                                </columns>

                            </TableView>

                        </VBox>

                    </VBox>

                    <!-- PANEL DERECHO -->
                    <VBox spacing="16" prefWidth="380">

                        <!-- RESUMEN -->
                        <VBox styleClass="cardPanel" spacing="14">

                            <Label text="Resumen de la orden" styleClass="cardTitle"/>

                            <HBox spacing="12">

                                <VBox styleClass="miniCardGreen" prefWidth="150">
                                    <Label text="Productos"/>
                                    <Label text="8" styleClass="metricValueSmall"/>
                                </VBox>

                                <VBox styleClass="miniCardBlue" prefWidth="150">
                                    <Label text="Personas"/>
                                    <Label text="4" styleClass="metricValueSmall"/>
                                </VBox>

                            </HBox>

                            <HBox spacing="12">

                                <VBox styleClass="miniCardOrange" prefWidth="150">
                                    <Label text="Preparados"/>
                                    <Label text="5" styleClass="metricValueSmall"/>
                                </VBox>

                                <VBox styleClass="miniCardRed" prefWidth="150">
                                    <Label text="Pendientes"/>
                                    <Label text="3" styleClass="metricValueSmall"/>
                                </VBox>

                            </HBox>

                        </VBox>

                        <!-- OBSERVACIONES -->
                        <VBox styleClass="cardPanel" spacing="12">

                            <Label text="Notas y observaciones" styleClass="cardTitle"/>

                            <TextArea prefHeight="180"
                                      wrapText="true"
                                      promptText="Indicaciones especiales para cocina o delivery..."/>

                            <Button text="Guardar observaciones" styleClass="actionGreen"/>

                        </VBox>

                        <!-- TOTALES -->
                        <VBox styleClass="cardPanel" spacing="12">

                            <Label text="Totales" styleClass="cardTitle"/>

                            <GridPane hgap="14" vgap="12">

                                <Label text="Subtotal:"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="0"/>

                                <Label text="RD$ 2,850.00"
                                       styleClass="metricSub"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                                <Label text="ITBIS:"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="0"/>

                                <Label text="RD$ 513.00"
                                       styleClass="metricSub"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                                <Label text="Descuento:"
                                       GridPane.rowIndex="2"
                                       GridPane.columnIndex="0"/>

                                <TextField promptText="0.00"
                                           prefWidth="120"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1"/>

                                <Label text="Total:"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="0"/>

                                <Label text="RD$ 3,363.00"
                                       styleClass="metricValueSmall"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="1"/>

                            </GridPane>

                            <Button text="Ir a pago"
                                    onAction="#procesarPago"
                                    prefHeight="46"
                                    styleClass="actionGreen"/>

                        </VBox>

                    </VBox>

                </HBox>

            </VBox>

            <VBox fx:id="viewPago" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">

                    <VBox>
                        <Label text="Pago" styleClass="pageTitle"/>
                        <Label text="Procesa el cobro y confirma la venta." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="↻ Actualizar" onAction="#actualizarPagoView" styleClass="actionNeutral"/>
                    <Button text="✖ Cancelar pago" onAction="#cancelarPagoView" styleClass="actionRed"/>
                    <Button text="🧾 Facturar" onAction="#facturarDesdeViewPago" styleClass="actionBlue"/>
                    <Button text="✔ Confirmar pago" onAction="#procesarPago" styleClass="actionGreen"/>

                </HBox>

                <HBox spacing="16">

                    <!-- PANEL IZQUIERDO -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- RESUMEN -->
                        <VBox styleClass="cardPanel" spacing="14">

                            <Label text="Resumen de la orden" styleClass="cardTitle"/>

                            <GridPane hgap="18" vgap="12">

                                <Label text="Orden:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField text="ORD-000125" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Cliente:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <TextField text="Juan Pérez García" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Mesa:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField text="Mesa 05" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Tipo venta:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                <TextField text="Salón" editable="false" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                <Label text="Cajero:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField text="Admin" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            </GridPane>

                        </VBox>

                        <!-- PRODUCTOS -->
                        <VBox styleClass="cardPanel" spacing="12">

                            <HBox alignment="CENTER_LEFT">
                                <Label text="Productos de la orden" styleClass="cardTitle"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="🖨 Imprimir pre cuenta" styleClass="actionNeutral"/>
                            </HBox>

                            <TableView prefHeight="340">

                                <columns>

                                    <TableColumn text="Producto" prefWidth="260"/>
                                    <TableColumn text="Cant." prefWidth="80"/>
                                    <TableColumn text="Precio" prefWidth="120"/>
                                    <TableColumn text="Subtotal" prefWidth="140"/>

                                </columns>

                            </TableView>

                        </VBox>

                    </VBox>

                    <!-- PANEL DERECHO -->
                    <VBox spacing="16" prefWidth="420">

                        <!-- METODOS -->
                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Método de pago" styleClass="cardTitle"/>

                            <GridPane hgap="10" vgap="10">
                                <Button text="💵 Efectivo" styleClass="paymentOptionActive" prefWidth="150" prefHeight="48"
                                        GridPane.rowIndex="0" GridPane.columnIndex="0"/>

                                <Button text="💳 Tarjeta" styleClass="paymentOption" prefWidth="150" prefHeight="48"
                                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Button text="🏦 Transferencia" styleClass="paymentOption" prefWidth="150" prefHeight="48"
                                        GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                                <Button text="🔀 Pago mixto" styleClass="paymentOption" prefWidth="150" prefHeight="48"
                                        GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            </GridPane>
                        </VBox>

                        <!-- MONTOS -->
                        <VBox styleClass="cardPanel" spacing="14">

                            <Label text="Montos" styleClass="cardTitle"/>

                            <GridPane hgap="14" vgap="12">

                                <Label text="Subtotal:"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="0"/>

                                <Label text="RD$ 2,850.00"
                                       styleClass="metricSub"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                                <Label text="ITBIS:"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="0"/>

