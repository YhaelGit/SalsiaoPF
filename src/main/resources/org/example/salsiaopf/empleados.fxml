<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.EmpleadosController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage" fitWidth="82" fitHeight="82" preserveRatio="true"/>
            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Empleados" styleClass="brandSubtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>
            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>
                <Button fx:id="btnNotificaciones" text="🔔 0" onAction="#mostrarNotificaciones" styleClass="notificationModernButton"/>
                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="EMPLEADOS" styleClass="sideTitle"/>
            <Button text="📊  Dashboard" onAction="#mostrarDashboard" styleClass="sideButtonActive"/>
            <Button text="📝  Registrar" onAction="#mostrarRegistrar" styleClass="sideButton"/>
            <Button text="🏷  Cargos/Roles" onAction="#mostrarCargos" styleClass="sideButton"/>
            <Button text="🕒  Asistencia" onAction="#mostrarAsistencia" styleClass="sideButton"/>
            <Button text="📅  Turnos/Horarios" onAction="#mostrarTurnos" styleClass="sideButton"/>
            <Button text="🔐  Usuarios" onAction="#mostrarUsuarios" styleClass="sideButton"/>
            <Button text="📋  Historial" onAction="#mostrarHistorial" styleClass="sideButton"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox styleClass="userCard">
                <Label text="Empleados" styleClass="userCardName"/>
                <Label text="Gestión del personal." wrapText="true" styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorEmpleados" styleClass="contentArea">

            <!-- ═══════════════ DASHBOARD ═══════════════ -->
            <ScrollPane fx:id="scrollDashboard" fitToWidth="true" fitToHeight="true" visible="true" managed="true" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Dashboard de empleados" styleClass="pageTitle"/>
                        <Label text="Resumen general del personal." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo empleado" onAction="#nuevoEmpleado" styleClass="actionBlue"/>
                    <Button text="🕒 Registrar asistencia" onAction="#irARegistrarAsistencia" styleClass="actionGreen"/>
                    <Button text="📅 Asignar turno" onAction="#irATurnos" styleClass="actionOrange"/>
                    <Button text="↻ Limpiar" onAction="#limpiarDashboard" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="200" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Empleados activos" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblActivos" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="200" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Inactivos" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblInactivos" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="200" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Asistencias hoy" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblAsistenciasHoy" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="200" prefHeight="85" GridPane.columnIndex="3">
                        <Label text="Total empleados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalEmpleados" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Listado de empleados" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtBuscarEmpleado" promptText="Buscar empleado..." prefWidth="240" onKeyReleased="#filtrarEmpleados"/>
                        <ComboBox fx:id="cmbFiltroCargo" promptText="Filtrar por cargo" prefWidth="180" onAction="#filtrarEmpleados"/>
                        <ComboBox fx:id="cmbFiltroEstado" promptText="Filtrar por estado" prefWidth="160" onAction="#filtrarEmpleados"/>
                        <Button text="📄 Exportar" onAction="#exportarEmpleados" styleClass="actionBlue"/>
                        <Button text="↻ Limpiar" onAction="#limpiarDashboard" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaEmpleados" prefHeight="380" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="100"/>
                            <TableColumn text="Nombre completo" prefWidth="200"/>
                            <TableColumn text="Cédula" prefWidth="140"/>
                            <TableColumn text="Cargo" prefWidth="140"/>
                            <TableColumn text="Teléfono" prefWidth="130"/>
                            <TableColumn text="Turno" prefWidth="100"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="F. Ingreso" prefWidth="120"/>
                            <TableColumn text="Acciones" prefWidth="220"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ REGISTRAR EMPLEADO ═══════════════ -->
            <ScrollPane fx:id="scrollRegistrar" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Registrar empleado" styleClass="pageTitle"/>
                        <Label text="Complete los datos del nuevo empleado." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="💾 Guardar" onAction="#guardarEmpleado" styleClass="actionGreen"/>
                    <Button text="❌ Cancelar" onAction="#cancelarEdicion" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFormulario" styleClass="actionNeutral"/>
                    <Button text="← Volver" onAction="#volverADashboard" styleClass="actionOrange"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="16">
                    <Label text="Datos del empleado" styleClass="cardTitle"/>
                    <GridPane hgap="18" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtCodigo" editable="false" promptText="Generado automáticamente" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Cédula:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtCedula" promptText="000-0000000-0" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombre" promptText="Nombre del empleado" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Apellido:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtApellido" promptText="Apellido del empleado" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Teléfono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtTelefono" promptText="809-000-0000" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Correo:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        <Label text="Dirección:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtDireccion" promptText="Dirección completa" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

                        <Label text="Cargo:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbCargo" promptText="Seleccione cargo" editable="true" prefWidth="220" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                        <Label text="Área:" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbArea" promptText="Departamento o área" editable="true" prefWidth="220" GridPane.rowIndex="4" GridPane.columnIndex="3"/>

                        <Label text="Turno:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbTurno" promptText="Seleccione turno" prefWidth="220" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                        <Label text="Sueldo:" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtSueldo" promptText="0.00" GridPane.rowIndex="5" GridPane.columnIndex="3"/>

                        <Label text="Fecha ingreso:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <DatePicker fx:id="dateIngreso" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                        <Label text="Estado:" GridPane.rowIndex="6" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbEstado" promptText="Estado inicial" prefWidth="220" GridPane.rowIndex="6" GridPane.columnIndex="3"/>

                        <Label text="Observación:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtObservacion" promptText="Notas del empleado..." prefRowCount="2" wrapText="true" GridPane.rowIndex="7" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de empleados" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField promptText="Buscar empleado..." prefWidth="240"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaRegistroEmpleados" prefHeight="300" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Código" prefWidth="100"/>
                            <TableColumn text="Nombre" prefWidth="180"/>
                            <TableColumn text="Cédula" prefWidth="140"/>
                            <TableColumn text="Cargo" prefWidth="130"/>
                            <TableColumn text="Turno" prefWidth="100"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Acciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ CARGOS/ROLES ═══════════════ -->
            <ScrollPane fx:id="scrollCargos" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Cargos / Roles" styleClass="pageTitle"/>
                        <Label text="Administra los cargos y roles del personal." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo cargo" onAction="#nuevoCargo" styleClass="actionBlue"/>
                    <Button text="💾 Guardar" onAction="#guardarCargo" styleClass="actionGreen"/>
                    <Button text="❌ Cancelar" onAction="#cancelarEdicion" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFormCargo" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del cargo" styleClass="cardTitle"/>
                        <GridPane hgap="18" vgap="10">
                            <Label text="ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtIdCargo" editable="false" promptText="Automático" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombreCargo" promptText="Nombre del cargo (ej: Cocinero)" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Estado:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbEstadoCargo" promptText="Activo" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                            <Label text="Descripción:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextArea fx:id="txtDescCargo" promptText="Descripción del cargo..." prefRowCount="3" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                        </GridPane>
                    </VBox>
                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de cargos" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtBuscarCargo" promptText="Buscar cargo..." prefWidth="240" onKeyReleased="#filtrarCargos"/>
                        <Button text="📄 Exportar" onAction="#exportarCargos" styleClass="actionBlue"/>
                        <Button text="↻ Limpiar" onAction="#limpiarFormCargo" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaCargos" prefHeight="380" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="80"/>
                            <TableColumn text="Nombre" prefWidth="200"/>
                            <TableColumn text="Descripción" prefWidth="300"/>
                            <TableColumn text="Empleados" prefWidth="120"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Acciones" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ ASISTENCIA ═══════════════ -->
            <ScrollPane fx:id="scrollAsistencia" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Asistencia" styleClass="pageTitle"/>
                        <Label text="Registra y consulta entradas, salidas y ausencias." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🟢 Registrar entrada" onAction="#registrarEntrada" styleClass="actionGreen"/>
                    <Button text="🔴 Registrar salida" onAction="#registrarSalida" styleClass="actionRed"/>
                    <Button text="⛔ Marcar ausencia" onAction="#marcarAusencia" styleClass="actionOrange"/>
                    <Button text="📄 Exportar" onAction="#exportarAsistencias" styleClass="actionBlue"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFiltrosAsistencia" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="200" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Presentes hoy" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblPresentesHoy" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="200" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Tardanzas" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTardanzasHoy" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="200" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Ausentes" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblAusentesHoy" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="200" prefHeight="85" GridPane.columnIndex="3">
                        <Label text="Total registros" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalAsistencias" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Registro de asistencia" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <DatePicker fx:id="dateFiltroAsistencia" promptText="Filtrar fecha" onAction="#filtrarAsistencias"/>
                        <ComboBox fx:id="cmbFiltroEstadoAsistencia" promptText="Estado" prefWidth="150" onAction="#filtrarAsistencias"/>
                        <TextField fx:id="txtBuscarAsistencia" promptText="Buscar empleado..." prefWidth="200" onKeyReleased="#filtrarAsistencias"/>
                        <Button text="📄 Exportar" onAction="#exportarAsistencias" styleClass="actionBlue"/>
                        <Button text="↻ Limpiar" onAction="#limpiarFiltrosAsistencia" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaAsistencia" prefHeight="400" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Empleado" prefWidth="200"/>
                            <TableColumn text="Fecha" prefWidth="120"/>
                            <TableColumn text="Entrada" prefWidth="100"/>
                            <TableColumn text="Salida" prefWidth="100"/>
                            <TableColumn text="Estado" prefWidth="120"/>
                            <TableColumn text="Observación" prefWidth="250"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ TURNOS/HORARIOS ═══════════════ -->
            <ScrollPane fx:id="scrollTurnos" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Turnos / Horarios" styleClass="pageTitle"/>
                        <Label text="Administra los horarios y turnos del personal." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo turno" onAction="#nuevoTurno" styleClass="actionBlue"/>
                    <Button text="💾 Guardar" onAction="#guardarTurno" styleClass="actionGreen"/>
                    <Button text="❌ Cancelar" onAction="#cancelarEdicion" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFormTurno" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="14">
                    <Label text="Asignar horario" styleClass="cardTitle"/>
                    <GridPane hgap="18" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="Empleado:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbEmpleadoTurno" promptText="Seleccione empleado" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Día:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbDiaTurno" promptText="Lunes, Martes..." prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Hora entrada:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtHoraEntradaTurno" promptText="08:00 AM" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Hora salida:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtHoraSalidaTurno" promptText="05:00 PM" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Observación:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtObsTurno" promptText="Notas del horario..." prefRowCount="2" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de turnos" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtBuscarTurno" promptText="Buscar turno..." prefWidth="240" onKeyReleased="#filtrarTurnos"/>
                        <ComboBox fx:id="cmbFiltroDiaTurno" promptText="Filtrar por día" prefWidth="160" onAction="#filtrarTurnos"/>
                        <Button text="↻ Limpiar" onAction="#limpiarFormTurno" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaTurnos" prefHeight="380" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Empleado" prefWidth="180"/>
                            <TableColumn text="Cargo" prefWidth="130"/>
                            <TableColumn text="Día" prefWidth="110"/>
                            <TableColumn text="Entrada" prefWidth="100"/>
                            <TableColumn text="Salida" prefWidth="100"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Acciones" prefWidth="180"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ USUARIOS ═══════════════ -->
            <ScrollPane fx:id="scrollUsuarios" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Usuarios del sistema" styleClass="pageTitle"/>
                        <Label text="Controla accesos, roles y credenciales del sistema." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nuevo usuario" onAction="#nuevoUsuario" styleClass="actionBlue"/>
                    <Button text="🔑 Cambiar contraseña" onAction="#cambiarContrasena" styleClass="actionOrange"/>
                    <Button text="💾 Guardar" onAction="#guardarUsuario" styleClass="actionGreen"/>
                    <Button text="❌ Cancelar" onAction="#cancelarEdicion" styleClass="actionRed"/>
                    <Button text="↻ Limpiar" onAction="#limpiarFormUsuario" styleClass="actionNeutral"/>
                </HBox>

                <VBox styleClass="cardPanel" spacing="14">
                    <Label text="Datos de acceso" styleClass="cardTitle"/>
                    <GridPane hgap="18" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints minWidth="220" prefWidth="220"/>
                        </columnConstraints>

                        <Label text="ID Usuario:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtIdUsuario" editable="false" promptText="Automático" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Empleado:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbEmpleadoUsuario" promptText="Seleccionar empleado" prefWidth="220" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                        <Label text="Usuario:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombreUsuario" promptText="Nombre de usuario" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Rol:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="cmbRolUsuario" promptText="Rol del sistema" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                        <Label text="Contraseña:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="txtPasswordUsuario" promptText="Contraseña" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Confirmar:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                        <PasswordField fx:id="txtConfirmarPassword" promptText="Confirmar contraseña" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        <Label text="Estado:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="cmbEstadoUsuario" promptText="Activo" prefWidth="220" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Permisos:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtPermisosUsuario" promptText="Separados por coma: ver,crear,editar" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                    </GridPane>
                </VBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de usuarios" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtBuscarUsuario" promptText="Buscar usuario..." prefWidth="240" onKeyReleased="#filtrarUsuarios"/>
                        <Button text="↻ Limpiar" onAction="#limpiarFormUsuario" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaUsuarios" prefHeight="380" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Empleado" prefWidth="180"/>
                            <TableColumn text="Usuario" prefWidth="150"/>
                            <TableColumn text="Rol" prefWidth="130"/>
                            <TableColumn text="Estado" prefWidth="100"/>
                            <TableColumn text="Último acceso" prefWidth="180"/>
                            <TableColumn text="Acciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ═══════════════ HISTORIAL ═══════════════ -->
            <ScrollPane fx:id="scrollHistorial" fitToWidth="true" fitToHeight="true" visible="false" managed="false" styleClass="contentScroll">
            <VBox spacing="16" styleClass="content">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Historial de empleados" styleClass="pageTitle"/>
                        <Label text="Consulta movimientos, cambios y eventos del personal." styleClass="pageSubtitle"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="📄 Exportar" onAction="#exportarHistorial" styleClass="actionBlue"/>
                    <Button text="↻ Actualizar" onAction="#actualizarHistorial" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardBlue" prefWidth="200" prefHeight="85" GridPane.columnIndex="0">
                        <Label text="Eventos registrados" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblTotalEventos" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardOrange" prefWidth="200" prefHeight="85" GridPane.columnIndex="1">
                        <Label text="Cambios de cargo" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblCambiosCargo" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardGreen" prefWidth="200" prefHeight="85" GridPane.columnIndex="2">
                        <Label text="Asistencias" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblHistorialAsistencias" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4" styleClass="statusCardRed" prefWidth="200" prefHeight="85" GridPane.columnIndex="3">
                        <Label text="Incidencias" style="-fx-text-fill: #000000;"/>
                        <Label fx:id="lblIncidencias" text="0" styleClass="metricValueSmall"/>
                    </VBox>
                </GridPane>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Movimientos del personal" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <DatePicker fx:id="dateHistorialDesde" promptText="Desde" onAction="#filtrarHistorial"/>
                        <DatePicker fx:id="dateHistorialHasta" promptText="Hasta" onAction="#filtrarHistorial"/>
                        <ComboBox fx:id="cmbFiltroTipoEvento" promptText="Tipo evento" prefWidth="160" onAction="#filtrarHistorial"/>
                        <TextField fx:id="txtBuscarHistorial" promptText="Buscar historial..." prefWidth="200" onKeyReleased="#filtrarHistorial"/>
                        <Button text="📄 Exportar" onAction="#exportarHistorial" styleClass="actionBlue"/>
                        <Button text="↻ Limpiar" onAction="#limpiarFiltrosHistorial" styleClass="actionNeutral"/>
                    </HBox>
                    <TableView fx:id="tablaHistorial" prefHeight="400" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Fecha" prefWidth="110"/>
                            <TableColumn text="Hora" prefWidth="90"/>
                            <TableColumn text="Empleado" prefWidth="200"/>
                            <TableColumn text="Tipo evento" prefWidth="150"/>
                            <TableColumn text="Descripción" prefWidth="350"/>
                            <TableColumn text="Usuario" prefWidth="130"/>
                            <TableColumn text="Módulo" prefWidth="120"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

        </StackPane>
    </center>

</BorderPane>
