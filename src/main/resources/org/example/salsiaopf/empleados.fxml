<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.EmpleadosController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Gestión de Empleado" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="☰ Volver" onAction="#volverMenu" styleClass="topButton"/>

            <HBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="📅" styleClass="topIcon"/>
                    <Label fx:id="lblFechaActual" text="--/--/----" styleClass="topInfoText"/>
                </HBox>

                <HBox alignment="CENTER" spacing="6" styleClass="topInfoCard">
                    <Label text="🕒" styleClass="topIcon"/>
                    <Label fx:id="lblHoraActual" text="--:-- --" styleClass="topInfoText"/>
                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 0"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER" spacing="8" styleClass="userInfoCard">
                    <Label text="👤" styleClass="topIcon"/>
                    <VBox spacing="0">
                        <Label text="Admin" styleClass="userNameTop"/>
                        <Label text="Administrador" styleClass="userRoleTop"/>
                    </VBox>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="EMPLEADOS" styleClass="sideTitle"/>

            <Button fx:id="btnRegistroEmpleado" text="👤  Registro de empleados" onAction="#mostrarRegistroEmpleado" styleClass="sideButtonActive"/>
            <Button fx:id="btnNomina" text="💰 Nómina" onAction="#mostrarNomina" styleClass="sideButton"/>
            <Button fx:id="btnUsuariosSistema" text="🔐  Usuarios del sistema" onAction="#mostrarUsuariosSistema" styleClass="sideButton"/>
            <Button fx:id="btnRolesPermisos" text="🛡  Roles y permisos" onAction="#mostrarRolesPermisos" styleClass="sideButton"/>
            <Button fx:id="btnAsistencia" text="🕒  Asistencia" onAction="#mostrarAsistencia" styleClass="sideButton"/>
            <Button fx:id="btnHorarios" text="📅  Horarios" onAction="#mostrarHorarios" styleClass="sideButton"/>
            <Button fx:id="btnHistorialEmpleados" text="↺  Historial empleados" onAction="#mostrarHistorialEmpleados" styleClass="sideButton"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="userCard">
                <Label text="Empleado"
                       styleClass="userCardName"/>

                <Label text="Gestión del empleado."
                       wrapText="true"
                       styleClass="userCardRole"/>
            </VBox>
            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contenedorEmpleados" styleClass="contentArea">

            <!-- REGISTRO DE EMPLEADOS -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewRegistroEmpleado" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Registro de empleados" styleClass="pageTitle"/>
                        <Label text="Administra los datos personales, cargo, área y estado laboral." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo empleado" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🗑 Eliminar" styleClass="actionRed"/>
                    <Button text="💾 Guardar" onAction="#guardarRegistroEmpleado" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" onAction="#limpiarRegistroEmpleado" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos del empleado" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Empleado:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtIdEmpleado" editable="false" promptText="Automático" prefWidth="260"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Cédula:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtCedulaEmpleado" promptText="000-0000000-0" prefWidth="250"
                                       GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Nombre:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombreEmpleado" promptText="Nombre" prefWidth="260"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Apellido:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtApellidoEmpleado" promptText="Apellido" prefWidth="250"
                                       GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Teléfono:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtTelefonoEmpleado" promptText="Teléfono" prefWidth="260"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Correo:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtCorreoEmpleado" promptText="Correo opcional" prefWidth="250"
                                       GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Cargo:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbCargoEmpleado" promptText="Cargo" prefWidth="260"
                                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Departamento:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbDepartamentoEmpleado" promptText="Departamento" prefWidth="250"
                                      GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Fecha ingreso:" minWidth="140" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <DatePicker fx:id="dateIngresoEmpleado" prefWidth="260"
                                        GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbEstadoEmpleado" promptText="Activo" prefWidth="250"
                                      GridPane.rowIndex="4" GridPane.columnIndex="3"/>

                            <Label text="Dirección:" minWidth="140" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtDireccionEmpleado" promptText="Dirección" prefWidth="260"
                                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                            <Label text="Referencia:" minWidth="140" GridPane.rowIndex="5" GridPane.columnIndex="2"/>
                            <TextArea fx:id="txtReferenciaEmpleado" promptText="Referencia u observación..."
                                      prefRowCount="3" prefWidth="250"
                                      GridPane.rowIndex="5" GridPane.columnIndex="3"/>
                        </GridPane>
                    </VBox>

                    <VBox spacing="16" prefWidth="390">
                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Resumen empleados" styleClass="cardTitle"/>

                            <HBox><Label text="Activos:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="Inactivos:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="Usuarios:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="En turno:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        </VBox>

                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Acciones rápidas" styleClass="cardTitle"/>

                            <Button text="🔐 Crear usuario" styleClass="actionBlue" prefHeight="42"/>
                            <Button text="🕒 Registrar asistencia" styleClass="actionGreen" prefHeight="42"/>
                            <Button text="📅 Asignar horario" styleClass="actionOrange" prefHeight="42"/>
                            <Button text="📄 Exportar empleados" styleClass="actionNeutral" prefHeight="42"/>
                        </VBox>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de empleados" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField promptText="Buscar empleado..." prefWidth="240"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaEmpleados" prefHeight="380" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="90"/>
                            <TableColumn text="Empleado" prefWidth="140"/>
                            <TableColumn text="Cédula" prefWidth="150"/>
                            <TableColumn text="Teléfono" prefWidth="150"/>
                            <TableColumn text="Cargo" prefWidth="180"/>
                            <TableColumn text="Departamento" prefWidth="140"/>
                            <TableColumn text="Fecha ingreso" prefWidth="160"/>
                            <TableColumn text="Estado" prefWidth="130"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewNomina"
                  styleClass="content"
                  spacing="16"
                  visible="false"
                  managed="false">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Nómina y estado laboral" styleClass="pageTitle"/>
                        <Label text="Gestiona sueldos, ingresos, deducciones, pagos, vacaciones, suspensiones, despidos y liquidaciones." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="💰 Procesar nómina" styleClass="actionBlue"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="📄 Exportar" styleClass="actionBlue"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <GridPane hgap="16">

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardGreen" prefWidth="220" prefHeight="95" GridPane.columnIndex="0">
                        <Label text="Empleados activos"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="En nómina"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardBlue" prefWidth="220" prefHeight="95" GridPane.columnIndex="1">
                        <Label text="Nómina pendiente"/>
                        <Label text="RD$ 0.00" styleClass="metricValueSmall"/>
                        <Label text="Por procesar"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardOrange" prefWidth="220" prefHeight="95" GridPane.columnIndex="2">
                        <Label text="Deducciones"/>
                        <Label text="RD$ 0.00" styleClass="metricValueSmall"/>
                        <Label text="AFP / SFS / ISR"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6" styleClass="statusCardRed" prefWidth="220" prefHeight="95" GridPane.columnIndex="3">
                        <Label text="Desvinculados"/>
                        <Label text="0" styleClass="metricValueSmall"/>
                        <Label text="Renuncia / despido"/>
                    </VBox>

                </GridPane>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">

                        <Label text="Datos de nómina" styleClass="cardTitle"/>

                        <GridPane hgap="16" vgap="12">

                            <columnConstraints>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="220" prefWidth="220"/>
                                <ColumnConstraints minWidth="130" prefWidth="130"/>
                                <ColumnConstraints minWidth="220" prefWidth="220"/>
                            </columnConstraints>

                            <Label text="Empleado:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField promptText="Nombre del empleado" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="ID empleado:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField promptText="Automático" editable="false" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Cargo:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField promptText="Cargo del empleado" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Periodo:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox promptText="Semanal / Quincenal / Mensual" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Fecha desde:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <DatePicker GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Fecha hasta:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <DatePicker GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                        </GridPane>

                        <Separator/>

                        <HBox spacing="16">

                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Ingresos" styleClass="cardTitle"/>

                                <GridPane hgap="12" vgap="10">
                                    <Label text="Sueldo base:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="Horas extra:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                    <Label text="Bonificación:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                    <Label text="Otros ingresos:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                    <Label text="Total ingresos:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" editable="false" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                </GridPane>
                            </VBox>

                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Deducciones" styleClass="cardTitle"/>

                                <GridPane hgap="12" vgap="10">
                                    <Label text="AFP:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                    <Label text="SFS:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                    <Label text="ISR:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                    <Label text="Descuentos:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                    <Label text="Total deducciones:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                    <TextField promptText="0.00" editable="false" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                </GridPane>
                            </VBox>

                            <VBox spacing="10" prefWidth="240">
                                <Label text="Resultado" styleClass="cardTitle"/>

                                <VBox alignment="CENTER" spacing="8" styleClass="statusCardGreen" prefHeight="150">
                                    <Label text="Neto a pagar"/>
                                    <Label text="RD$ 0.00" styleClass="metricValueSmall"/>
                                    <Label text="Resultado final"/>
                                </VBox>

                                <Button text="Calcular nómina" styleClass="actionBlue" maxWidth="Infinity"/>
                                <Button text="Registrar pago" styleClass="actionGreen" maxWidth="Infinity"/>

                                <Button text="Guardar estado laboral"
                                        styleClass="actionGreen"
                                        maxWidth="Infinity"/>

                                <Button text="Marcar desvinculado"
                                        styleClass="actionRed"
                                        maxWidth="Infinity"/>

                                <Button text="Limpiar"
                                        styleClass="actionNeutral"
                                        maxWidth="Infinity"/>
                            </VBox>

                        </HBox>

                    </VBox>

                    <VBox styleClass="cardPanel compactPanel" spacing="10" prefWidth="320" minWidth="320" maxWidth="320">

                        <Label text="Estado laboral" styleClass="cardTitle"/>

                        <Label text="Estado actual:"/>
                        <ComboBox promptText="Activo / Suspendido / Desvinculado"/>

                        <Label text="Tipo movimiento:"/>
                        <ComboBox promptText="Vacaciones / Permiso / Suspensión / Renuncia / Despido"/>

                        <Label text="Fecha ingreso:"/>
                        <DatePicker/>

                        <Label text="Fecha salida:"/>
                        <DatePicker/>

                        <Label text="Motivo:"/>
                        <TextField promptText="Motivo del movimiento"/>

                        <Label text="Liquidación:"/>
                        <TextField promptText="0.00"/>

                        <Label text="Observación:"/>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12" VBox.vgrow="ALWAYS">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Historial de nómina" styleClass="cardTitle"/>

                        <Region HBox.hgrow="ALWAYS"/>

                        <DatePicker promptText="Desde" prefWidth="140"/>
                        <DatePicker promptText="Hasta" prefWidth="140"/>
                        <ComboBox promptText="Estado" prefWidth="150"/>
                        <TextField promptText="Buscar empleado..." prefWidth="230"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView prefHeight="300" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="80"/>
                            <TableColumn text="Empleado" prefWidth="220"/>
                            <TableColumn text="Periodo" prefWidth="130"/>
                            <TableColumn text="Sueldo base" prefWidth="130"/>
                            <TableColumn text="Ingresos" prefWidth="130"/>
                            <TableColumn text="Deducciones" prefWidth="140"/>
                            <TableColumn text="Neto" prefWidth="130"/>
                            <TableColumn text="Estado laboral" prefWidth="160"/>
                            <TableColumn text="Fecha pago" prefWidth="140"/>
                            <TableColumn text="Acciones" prefWidth="150"/>
                        </columns>
                    </TableView>

                </VBox>

            </VBox>
            </ScrollPane>

            <!-- USUARIOS -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewUsuariosSistema" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Usuarios del sistema" styleClass="pageTitle"/>
                        <Label text="Controla los accesos, usuarios, roles y estados de entrada al sistema." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo usuario" styleClass="actionBlue"/>
                    <Button text="✎ Editar" styleClass="actionOrange"/>
                    <Button text="🔒 Bloquear" styleClass="actionRed"/>
                    <Button text="💾 Guardar" styleClass="actionGreen"/>
                    <Button text="↻ Limpiar" styleClass="actionNeutral"/>
                </HBox>

                <HBox spacing="16">

                    <VBox styleClass="cardPanel" spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="Datos de acceso" styleClass="cardTitle"/>

                        <GridPane hgap="18" vgap="14">
                            <Label text="ID Usuario:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtIdUsuario" editable="false" promptText="Automático" prefWidth="260"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Empleado:" minWidth="140" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbEmpleadoUsuario" promptText="Seleccionar empleado" prefWidth="260"
                                      GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                            <Label text="Usuario:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtNombreUsuario" promptText="Nombre de usuario" prefWidth="260"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Rol:" minWidth="140" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <ComboBox fx:id="cmbRolUsuario" promptText="Rol del sistema" prefWidth="260"
                                      GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                            <Label text="Contraseña:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <PasswordField fx:id="txtPasswordUsuario" promptText="Contraseña" prefWidth="260"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Confirmar:" minWidth="140" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <PasswordField fx:id="txtConfirmarPasswordUsuario" promptText="Confirmar contraseña" prefWidth="260"
                                           GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                            <Label text="Estado:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="cmbEstadoUsuario" promptText="Activo" prefWidth="260"
                                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Último acceso:" minWidth="140" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtUltimoAccesoUsuario" editable="false" promptText="Sin acceso" prefWidth="260"
                                       GridPane.rowIndex="3" GridPane.columnIndex="3"/>

                            <Label text="Observación:" minWidth="140" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextArea fx:id="txtObservacionUsuario" promptText="Observaciones del usuario..."
                                      prefRowCount="3" prefWidth="260"
                                      GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <VBox spacing="16" prefWidth="390">
                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Resumen usuarios" styleClass="cardTitle"/>

                            <HBox><Label text="Usuarios activos:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="Bloqueados:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="Administradores:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                            <HBox><Label text="Últimos accesos:"/><Region HBox.hgrow="ALWAYS"/><Label text="0"/></HBox>
                        </VBox>

                        <VBox styleClass="cardPanel" spacing="12">
                            <Label text="Acciones rápidas" styleClass="cardTitle"/>

                            <Button text="🔑 Cambiar contraseña" styleClass="actionBlue" prefHeight="42"/>
                            <Button text="🛡 Asignar rol" styleClass="actionOrange" prefHeight="42"/>
                            <Button text="✔ Activar usuario" styleClass="actionGreen" prefHeight="42"/>
                            <Button text="🔒 Bloquear usuario" styleClass="actionRed" prefHeight="42"/>
                        </VBox>
                    </VBox>

                </HBox>

                <VBox styleClass="cardPanel" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Listado de usuarios" styleClass="cardTitle"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField promptText="Buscar usuario..." prefWidth="240"/>
                        <Button text="🔍" styleClass="actionNeutral"/>
                    </HBox>

                    <TableView fx:id="tablaUsuariosSistema" prefHeight="420" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="90"/>
                            <TableColumn text="Empleado" prefWidth="140"/>
                            <TableColumn text="Usuario" prefWidth="180"/>
                            <TableColumn text="Rol" prefWidth="170"/>
                            <TableColumn text="Estado" prefWidth="130"/>
                            <TableColumn text="Último acceso" prefWidth="180"/>
                            <TableColumn text="Creado por" prefWidth="160"/>
                            <TableColumn text="Acciones" prefWidth="200"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
            </ScrollPane>

            <!-- ROLES -->
            <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="contentScroll">
            <VBox fx:id="viewRolesPermisos" styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox>
                        <Label text="Roles y permisos" styleClass="pageTitle"/>
                        <Label text="Administra perfiles de acceso y permisos por módulo." styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="+ Nuevo rol" styleClass="actionBlue"/>
