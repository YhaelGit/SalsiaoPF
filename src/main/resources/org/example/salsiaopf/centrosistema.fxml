<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.salsiaopf.controller.CentroSistemaController"
            styleClass="appRoot">

    <top>
        <HBox styleClass="topBar" alignment="CENTER_LEFT" spacing="18">
            <ImageView fx:id="logoImage"
                       fitWidth="82"
                       fitHeight="82"
                       preserveRatio="true"/>

            <VBox>
                <Label text="Salsiao" styleClass="brandTitle"/>
                <Label text="Centro del Sistema" styleClass="brandSubtitle"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER"
                  spacing="14">

                <HBox alignment="CENTER"
                      spacing="6"
                      styleClass="topInfoCard">

                    <Label text="📅" styleClass="topIcon"/>

                    <Label fx:id="lblFechaActual"
                           text="15/05/2024"
                           styleClass="topInfoText"/>

                </HBox>

                <HBox alignment="CENTER"
                      spacing="6"
                      styleClass="topInfoCard">

                    <Label text="🕒"
                           styleClass="topIcon"/>

                    <Label fx:id="lblHoraActual"
                           text="02:35 PM"
                           styleClass="topInfoText"/>

                </HBox>

                <Button fx:id="btnNotificaciones"
                        text="🔔 3"
                        onAction="#mostrarNotificaciones"
                        styleClass="notificationModernButton"/>

                <HBox alignment="CENTER"
                      spacing="8"
                      styleClass="userInfoCard">

                    <Label text="👤"
                           styleClass="topIcon"/>

                    <VBox spacing="0">

                        <Label text="Admin"
                               styleClass="userNameTop"/>

                        <Label text="Administrador"
                               styleClass="userRoleTop"/>

                    </VBox>

                </HBox>

            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sideBar" spacing="12">
            <Label text="NAVEGACIÓN" styleClass="sideTitle"/>

            <Button text="🏠  General" onAction="#mostrarGeneral" styleClass="sideButtonActive"/>
            <Button text="🛒  Ventas" onAction="#abrirVentas" styleClass="sideButton"/>
            <Button text="🧾  Compras" onAction="#abrirCompras" styleClass="sideButton"/>
            <Button text="👥  Clientes" onAction="#abrirClientes" styleClass="sideButton"/>
            <Button text="📦  Inventario" onAction="#abrirInventario" styleClass="sideButton"/>
            <Button text="👤  Empleados" onAction="#abrirEmpleados" styleClass="sideButton"/>
            <Button text="🛠  Mantenimiento" onAction="#abrirMantenimiento" styleClass="sideButton"/>
            <Button text="📊  Reportes" onAction="#abrirReportes" styleClass="sideButton"/>
            <Button text="⚙  Configuración" onAction="#abrirConfiguracion" styleClass="sideButton"/>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox styleClass="userCard">
                <Label text="Admin" styleClass="userCardName"/>
                <Label text="Rol: Administrador" styleClass="userCardRole"/>
            </VBox>

            <Button text="↪  Salir" onAction="#salirSistema" styleClass="sideButtonExit"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="contentScroll">
            <VBox styleClass="content" spacing="16">

                <HBox alignment="CENTER_LEFT">
                    <VBox>
                        <Label text="Bienvenido, Admin 👋" styleClass="pageTitle"/>
                        <Label text="Resumen general del sistema" styleClass="pageSubtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="↻ Actualizar" styleClass="actionBlue"/>
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="metricCard" HBox.hgrow="ALWAYS">
                        <Label text="Ventas del día" styleClass="metricTitleGreen"/>
                        <Label text="RD$ 18,750.00" styleClass="metricValue"/>
                        <Label text="12 ventas" styleClass="metricSub"/>
                        <Label text="↑ 15% vs. ayer" styleClass="metricPositive"/>
                    </VBox>

                    <VBox styleClass="metricCard" HBox.hgrow="ALWAYS">
                        <Label text="Compras pendientes" styleClass="metricTitleBlue"/>
                        <Label text="5" styleClass="metricValue"/>
                        <Label text="Órdenes" styleClass="metricSub"/>
                        <Label text="RD$ 28,450.00" styleClass="metricSub"/>
                    </VBox>

                    <VBox styleClass="metricCard" HBox.hgrow="ALWAYS">
                        <Label text="Reservas hoy" styleClass="metricTitlePurple"/>
                        <Label text="8" styleClass="metricValue"/>
                        <Label text="Reservas" styleClass="metricSub"/>
                        <Label text="Próxima: 04:30 PM" styleClass="metricSub"/>
                    </VBox>

                    <VBox styleClass="metricCard" HBox.hgrow="ALWAYS">
                        <Label text="Clientes registrados" styleClass="metricTitleOrange"/>
                        <Label text="237" styleClass="metricValue"/>
                        <Label text="Clientes" styleClass="metricSub"/>
                        <Label text="+12 este mes" styleClass="metricOrange"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="panelLarge" HBox.hgrow="ALWAYS">
                        <Label text="Ventas de los últimos 7 días" styleClass="sectionTitle"/>
                        <Pane prefHeight="230" styleClass="chartPlaceholder">
                            <Label text="Gráfico de ventas" layoutX="260" layoutY="100" styleClass="placeholderText"/>
                        </Pane>
                        <Label text="Total semana: RD$ 112,350.00" styleClass="sectionFooter"/>
                    </VBox>

                    <VBox styleClass="panelSide" prefWidth="520">
                        <Label text="Notificaciones y alertas" styleClass="sectionTitle"/>
                        <Label text="🔴  3 reclamaciones pendientes - Requieren atención" styleClass="alertItem"/>
                        <Label text="🟡  Inventario bajo - 12 productos con stock mínimo" styleClass="alertItem"/>
                        <Label text="🔵  Mantenimiento programado - 2 equipos requieren mantenimiento" styleClass="alertItem"/>
                        <Label text="🟢  Pagos pendientes - 4 facturas por cobrar" styleClass="alertItem"/>
                        <Hyperlink text="Ver todas las notificaciones"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox styleClass="panelSmall" HBox.hgrow="ALWAYS">
                        <Label text="Productos más vendidos" styleClass="sectionTitle"/>
                        <Label text="1   Chicharrón de Pollo        45 unidades"/>
                        <Label text="2   Mofongo Especial          38 unidades"/>
                        <Label text="3   Jugo Natural              32 unidades"/>
                        <Label text="4   Tostones                  28 unidades"/>
                        <Label text="5   Hamburguesa Salsiao       25 unidades"/>
                    </VBox>

                    <VBox styleClass="panelSmall" HBox.hgrow="ALWAYS">
                        <Label text="Resumen de inventario" styleClass="sectionTitle"/>
                        <Label text="Total: 215 productos" styleClass="metricValueSmall"/>
                        <Label text="🟢 En stock: 142"/>
                        <Label text="🟡 Bajo stock: 42"/>
                        <Label text="🔴 Agotados: 31"/>
                        <Hyperlink text="Ver inventario completo"/>
                    </VBox>

                    <VBox styleClass="cardPanel" spacing="16">
                        <Label text="Accesos rápidos" styleClass="cardTitle"/>

                        <GridPane hgap="14" vgap="14">

                            <Button text="🛒 Nueva venta"
                                    onAction="#irNuevaVenta"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="0"
                                    GridPane.columnIndex="0"/>

                            <Button text="👤 Nuevo cliente"
                                    onAction="#irNuevoCliente"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="0"
                                    GridPane.columnIndex="1"/>

                            <Button text="🛍 Nueva compra"
                                    onAction="#irNuevaCompra"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="0"
                                    GridPane.columnIndex="2"/>

                            <Button text="📦 Nuevo producto"
                                    onAction="#irNuevoProducto"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="1"
                                    GridPane.columnIndex="0"/>

                            <Button text="📅 Nueva reserva"
                                    onAction="#irNuevaReserva"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="1"
                                    GridPane.columnIndex="1"/>

                            <Button text="📊 Reporte ventas"
                                    onAction="#irReporteVentas"
                                    styleClass="quickAccessButton"
                                    GridPane.rowIndex="1"
                                    GridPane.columnIndex="2"/>

                        </GridPane>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER">
                    <Label text="© 2026 Salsiao. Todos los derechos reservados." styleClass="footerText"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Versión 1.0.0" styleClass="footerText"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>