<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="caja_resumen"
              pageWidth="595" pageHeight="842"
              columnWidth="515" leftMargin="40" rightMargin="40"
              topMargin="30" bottomMargin="30"
              whenNoDataType="AllSectionsNoDetail"
>
    <property name="ireport.zoom" value="1.0"/>

    <parameter name="USUARIO" class="java.lang.String"/>
    <parameter name="APERTURA" class="java.lang.String"/>
    <parameter name="CIERRE" class="java.lang.String"/>
    <parameter name="MONTO_INICIAL" class="java.math.BigDecimal"/>
    <parameter name="EFECTIVO_DECLARADO" class="java.math.BigDecimal"/>
    <parameter name="EFECTIVO_ESPERADO" class="java.math.BigDecimal"/>
    <parameter name="TARJETA_DECLARADO" class="java.math.BigDecimal"/>
    <parameter name="TARJETA_ESPERADO" class="java.math.BigDecimal"/>
    <parameter name="TRANSFERENCIA_DECLARADO" class="java.math.BigDecimal"/>
    <parameter name="TRANSFERENCIA_ESPERADO" class="java.math.BigDecimal"/>
    <parameter name="TOTAL_DECLARADO" class="java.math.BigDecimal"/>
    <parameter name="TOTAL_ESPERADO" class="java.math.BigDecimal"/>
    <parameter name="DIFERENCIA" class="java.math.BigDecimal"/>

    <title>
        <band height="160">
            <rectangle radius="0">
                <reportElement mode="Opaque" x="0" y="0" width="515" height="110" backcolor="#2C3E50"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="30" y="14" width="455" height="34"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="26" isBold="true"/>
                </textElement>
                <text><![CDATA[SALSIAO RD]]></text>
            </staticText>
            <staticText>
                <reportElement x="30" y="52" width="455" height="18"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="12"/>
                </textElement>
                <text><![CDATA[Resumen de Cierre de Caja]]></text>
            </staticText>
            <line>
                <reportElement x="150" y="74" width="215" height="1" forecolor="#E67E22"/>
                <graphicElement><pen lineWidth="2.0"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="30" y="82" width="455" height="16"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="8"/>
                </textElement>
                <text><![CDATA[www.salsiao.com | contacto@salsiao.com | Tel: (809) 555-1234 | RNC: 1-31-12345-6]]></text>
            </staticText>
            <rectangle radius="4">
                <reportElement mode="Opaque" x="0" y="118" width="515" height="36" backcolor="#34495E"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="20" y="124" width="235" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="12" isBold="true"/>
                </textElement>
                <text><![CDATA[Usuario:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="100" y="124" width="180" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{USUARIO}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="310" y="124" width="185" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["Apertura: " + $P{APERTURA} + "  Cierre: " + $P{CIERRE}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <summary>
        <band height="480">
            <staticText>
                <reportElement x="20" y="20" width="230" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[Monto Inicial:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="250" y="20" width="245" height="22"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{MONTO_INICIAL}.doubleValue())]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="20" y="50" width="475" height="1" forecolor="#DEE2E6"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </line>

            <!-- Table header -->
            <rectangle radius="4">
                <reportElement mode="Opaque" x="20" y="60" width="475" height="28" backcolor="#2C3E50"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="30" y="62" width="160" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Metodo]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="62" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Declarado]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="62" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Esperado]]></text>
            </staticText>
            <staticText>
                <reportElement x="400" y="62" width="85" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Diferencia]]></text>
            </staticText>

            <!-- Efectivo -->
            <rectangle radius="2">
                <reportElement mode="Opaque" x="20" y="92" width="475" height="28" backcolor="#F0FDF4"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#D1FAE5"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="30" y="94" width="160" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Efectivo]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="200" y="94" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{EFECTIVO_DECLARADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="94" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{EFECTIVO_ESPERADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="400" y="94" width="85" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{EFECTIVO_DECLARADO}.subtract($P{EFECTIVO_ESPERADO}).doubleValue())]]></textFieldExpression>
            </textField>

            <!-- Tarjeta -->
            <rectangle radius="2">
                <reportElement mode="Opaque" x="20" y="124" width="475" height="28" backcolor="#EFF6FF"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#DBEAFE"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="30" y="126" width="160" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Tarjeta]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="200" y="126" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TARJETA_DECLARADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="126" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TARJETA_ESPERADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="400" y="126" width="85" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TARJETA_DECLARADO}.subtract($P{TARJETA_ESPERADO}).doubleValue())]]></textFieldExpression>
            </textField>

            <!-- Transferencia -->
            <rectangle radius="2">
                <reportElement mode="Opaque" x="20" y="156" width="475" height="28" backcolor="#FAF5FF"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#F3E8FF"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="30" y="158" width="160" height="24"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Transferencia]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="200" y="158" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TRANSFERENCIA_DECLARADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="158" width="100" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TRANSFERENCIA_ESPERADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="400" y="158" width="85" height="24"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TRANSFERENCIA_DECLARADO}.subtract($P{TRANSFERENCIA_ESPERADO}).doubleValue())]]></textFieldExpression>
            </textField>

            <!-- Separator -->
            <line>
                <reportElement x="20" y="196" width="475" height="1" forecolor="#2C3E50"/>
                <graphicElement><pen lineWidth="2.0"/></graphicElement>
            </line>

            <!-- TOTALS -->
            <staticText>
                <reportElement x="20" y="208" width="150" height="26"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Total:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="170" y="208" width="120" height="26"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TOTAL_DECLARADO}.doubleValue())]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="290" y="208" width="120" height="26"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14"/>
                </textElement>
                <text><![CDATA[Esperado:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="410" y="208" width="85" height="26"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="14"/>
                </textElement>
                <textFieldExpression><![CDATA["RD$ " + String.format("%,.2f", $P{TOTAL_ESPERADO}.doubleValue())]]></textFieldExpression>
            </textField>

            <!-- Diferencia -->
            <staticText>
                <reportElement x="20" y="242" width="150" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Diferencia:]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="170" y="242" width="325" height="30"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[
                    ($P{DIFERENCIA}.doubleValue() >= 0 ? "+" : "") + "RD$ " + String.format("%,.2f", $P{DIFERENCIA}.doubleValue())
                ]]></textFieldExpression>
            </textField>

            <!-- Footer -->
            <line>
                <reportElement x="20" y="300" width="475" height="1" forecolor="#34495E"/>
                <graphicElement><pen lineWidth="1.0"/></graphicElement>
            </line>
            <staticText>
                <reportElement x="20" y="310" width="475" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11" isItalic="true"/>
                </textElement>
                <text><![CDATA[Documento generado por Salsiao RD - Sistema de Gestion]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
